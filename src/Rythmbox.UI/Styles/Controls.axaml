<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:rb="using:Rythmbox.UI.Controls">

    <Styles.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://Rythmbox.UI/Styles/Tokens.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Styles.Resources>

    <!-- ═══════════════════════════════════════════════════════════════
         BASE TYPOGRAPHY
         ═══════════════════════════════════════════════════════════════ -->
    <Style Selector="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource RythmboxUIFont}" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxTextBrush}" />
    </Style>

    <Style Selector="TextBlock.rbLabel">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxDimTextBrush}" />
        <Setter Property="LetterSpacing" Value="0.6" />
    </Style>

    <Style Selector="TextBlock.rbValue">
        <Setter Property="FontFamily" Value="{StaticResource RythmboxUIMono}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="rb|RbValueDisplay">
        <Setter Property="Background" Value="{DynamicResource RbInputBgBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RbInputBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="CornerRadius" Value="{StaticResource RbRadiusInput}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style Selector="rb|RbLabeledField">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style Selector="TextBlock.rbSection">
        <Setter Property="FontSize" Value="9" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxDimTextBrush}" />
        <Setter Property="LetterSpacing" Value="1" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         BUTTON — default Ableton-style flat control
         Classes: accent | danger | ghost | secondary | icon | toolbar | compact
         ═══════════════════════════════════════════════════════════════ -->
    <Style Selector="Button">
        <Setter Property="FontFamily" Value="{StaticResource RythmboxUIFont}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Background" Value="{DynamicResource RbControlBgBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxTextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RbControlBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="{StaticResource RbPaddingControl}" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="CornerRadius" Value="{StaticResource RbRadiusControl}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RbControlHoverBrush}" />
    </Style>

    <Style Selector="Button:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RbControlPressedBrush}" />
    </Style>

    <Style Selector="Button:disabled">
        <Setter Property="Opacity" Value="0.42" />
    </Style>

    <Style Selector="Button.accent">
        <Setter Property="Background" Value="{DynamicResource RythmboxAccentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxOnAccentBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxAccentPressedBrush}" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxAccentHoverBrush}" />
    </Style>

    <Style Selector="Button.accent:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxAccentPressedBrush}" />
    </Style>

    <Style Selector="Button.creative">
        <Setter Property="Background" Value="{DynamicResource RythmboxCreativeMutedBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxCreativeBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxCreativeBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.creative:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxCreativeBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxOnAccentBrush}" />
    </Style>

    <Style Selector="Button.danger">
        <Setter Property="Background" Value="{DynamicResource RythmboxDangerSurfaceBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxRedBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxDangerBorderBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxDangerHoverBrush}" />
    </Style>

    <Style Selector="Button.ghost">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxDimTextBrush}" />
    </Style>

    <Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RbControlHoverBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RbControlBorderBrush}" />
    </Style>

    <Style Selector="Button.secondary">
        <Setter Property="Background" Value="{DynamicResource RythmboxElevatedBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
    </Style>

    <Style Selector="Button.icon">
        <Setter Property="Padding" Value="6" />
        <Setter Property="MinWidth" Value="28" />
        <Setter Property="MinHeight" Value="28" />
    </Style>

    <Style Selector="Button.toolbar, Button.toolbarBtn">
        <Setter Property="Padding" Value="{StaticResource RbPaddingCompact}" />
        <Setter Property="MinHeight" Value="26" />
        <Setter Property="Background" Value="{DynamicResource RbControlBgBrush}" />
    </Style>

    <Style Selector="Button.compact">
        <Setter Property="Padding" Value="6,3" />
        <Setter Property="MinHeight" Value="22" />
        <Setter Property="FontSize" Value="10" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         TOGGLE BUTTON — segment / on-off
         Classes: segment | segment.checked | ms | solo | mute
         ═══════════════════════════════════════════════════════════════ -->
    <Style Selector="ToggleButton">
        <Setter Property="FontFamily" Value="{StaticResource RythmboxUIFont}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Background" Value="{DynamicResource RbControlBgBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxDimTextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RbControlBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="{StaticResource RbPaddingCompact}" />
        <Setter Property="MinHeight" Value="26" />
        <Setter Property="CornerRadius" Value="{StaticResource RbRadiusControl}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="ToggleButton:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RbControlHoverBrush}" />
    </Style>

    <Style Selector="ToggleButton:checked /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RbControlActiveBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RbControlActiveBorderBrush}" />
    </Style>

    <Style Selector="ToggleButton:checked">
        <Setter Property="Foreground" Value="{DynamicResource RythmboxTextBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="ToggleButton.segment">
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Margin" Value="0" />
    </Style>

    <Style Selector="ToggleButton.segment:checked /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxAccentMutedBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxAccentBrush}" />
    </Style>

    <Style Selector="ToggleButton.segment:checked">
        <Setter Property="Foreground" Value="{DynamicResource RythmboxAccentBrush}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         TEXT BOX — inset field
         ═══════════════════════════════════════════════════════════════ -->
    <Style Selector="TextBox">
        <Setter Property="FontFamily" Value="{StaticResource RythmboxUIFont}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Background" Value="{DynamicResource RbInputBgBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxTextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RbInputBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="{StaticResource RbPaddingInput}" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="CornerRadius" Value="{StaticResource RbRadiusInput}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource RythmboxAccentBrush}" />
        <Setter Property="SelectionForegroundBrush" Value="#14151A" />
        <Setter Property="CaretBrush" Value="{DynamicResource RythmboxTextBrush}" />
    </Style>

    <Style Selector="TextBox:focus">
        <Setter Property="BorderBrush" Value="{DynamicResource RbInputFocusBorderBrush}" />
    </Style>

    <Style Selector="TextBox:disabled">
        <Setter Property="Opacity" Value="0.45" />
    </Style>

    <Style Selector="TextBox.compact">
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="Padding" Value="6,3" />
        <Setter Property="FontSize" Value="10" />
    </Style>

    <Style Selector="TextBox.mono">
        <Setter Property="FontFamily" Value="{StaticResource RythmboxUIMono}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         COMBO BOX
         ═══════════════════════════════════════════════════════════════ -->
    <Style Selector="ComboBox">
        <Setter Property="FontFamily" Value="{StaticResource RythmboxUIFont}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Background" Value="{DynamicResource RbInputBgBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxTextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RbInputBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="CornerRadius" Value="{StaticResource RbRadiusInput}" />
    </Style>

    <Style Selector="ComboBox:focus">
        <Setter Property="BorderBrush" Value="{DynamicResource RbInputFocusBorderBrush}" />
    </Style>

    <Style Selector="ComboBoxItem">
        <Setter Property="FontFamily" Value="{StaticResource RythmboxUIFont}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Padding" Value="10,6" />
    </Style>

    <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RbControlHoverBrush}" />
    </Style>

    <Style Selector="ComboBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RbControlActiveBrush}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         NUMERIC UP/DOWN
         ═══════════════════════════════════════════════════════════════ -->
    <Style Selector="NumericUpDown">
        <Setter Property="FontFamily" Value="{StaticResource RythmboxUIMono}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Background" Value="{DynamicResource RbInputBgBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxTextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RbInputBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="MinHeight" Value="26" />
        <Setter Property="CornerRadius" Value="{StaticResource RbRadiusInput}" />
    </Style>

    <Style Selector="NumericUpDown:focus">
        <Setter Property="BorderBrush" Value="{DynamicResource RbInputFocusBorderBrush}" />
    </Style>

    <Style Selector="NumericUpDown /template/ Button">
        <Setter Property="Background" Value="{DynamicResource RbControlBgBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RbControlBorderBrush}" />
        <Setter Property="MinWidth" Value="22" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         SLIDER — horizontal (vertical uses MixerFaderView)
         ═══════════════════════════════════════════════════════════════ -->
    <Style Selector="Slider">
        <Setter Property="Foreground" Value="{DynamicResource RbSliderFillBrush}" />
        <Setter Property="Background" Value="{DynamicResource RbSliderTrackBrush}" />
        <Setter Property="MinHeight" Value="20" />
        <Setter Property="rb:SliderBehaviors.WheelEnabled" Value="True" />
    </Style>

    <Style Selector="Slider /template/ Thumb#PART_Thumb">
        <Setter Property="Background" Value="{DynamicResource RbSliderThumbBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RbControlBorderBrush}" />
        <Setter Property="Width" Value="12" />
        <Setter Property="Height" Value="12" />
    </Style>

    <Style Selector="Slider /template/ Track#PART_Track">
        <Setter Property="Height" Value="4" />
    </Style>

    <Style Selector="Slider.rbAccent /template/ RepeatButton#PART_DecreaseButton /template/ Border">
        <Setter Property="Background" Value="{DynamicResource RbSliderFillBrush}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         TOGGLE SWITCH
         ═══════════════════════════════════════════════════════════════ -->
    <Style Selector="ToggleSwitch">
        <Setter Property="Foreground" Value="{DynamicResource RythmboxTextBrush}" />
        <Setter Property="FontSize" Value="10" />
    </Style>

    <Style Selector="ToggleSwitch:checked /template/ Border#SwitchKnobBounds">
        <Setter Property="Background" Value="{DynamicResource RythmboxAccentBrush}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         LIST BOX
         ═══════════════════════════════════════════════════════════════ -->
    <Style Selector="ListBox">
        <Setter Property="Background" Value="{DynamicResource RbInputBgBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RbInputBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RbRadiusInput}" />
        <Setter Property="Padding" Value="2" />
    </Style>

    <Style Selector="ListBoxItem">
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="CornerRadius" Value="1" />
        <Setter Property="FontSize" Value="11" />
    </Style>

    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RbControlHoverBrush}" />
    </Style>

    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RbControlActiveBrush}" />
    </Style>

    <Style Selector="ListBoxItem:selected">
        <Setter Property="Foreground" Value="{DynamicResource RythmboxTextBrush}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         MENU / CONTEXT
         ═══════════════════════════════════════════════════════════════ -->
    <Style Selector="MenuFlyoutPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxElevatedBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RbControlBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Padding" Value="4" />
    </Style>

    <Style Selector="MenuItem">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="CornerRadius" Value="1" />
    </Style>

    <Style Selector="MenuItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RbControlHoverBrush}" />
    </Style>

    <Style Selector="MenuItem:disabled">
        <Setter Property="Opacity" Value="0.42" />
    </Style>

    <!-- Menu separators / dividers: subtle 1px rule matching the panel border -->
    <Style Selector="MenuFlyoutPresenter Separator, ContextMenu Separator">
        <Setter Property="Background" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="Height" Value="1" />
        <Setter Property="Margin" Value="6,4" />
    </Style>

    <Style Selector="Separator">
        <Setter Property="Background" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="Height" Value="1" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         TOOLTIP — compact dark surface matching the workstation chrome
         ═══════════════════════════════════════════════════════════════ -->
    <Style Selector="ToolTip">
        <Setter Property="FontFamily" Value="{StaticResource RythmboxUIFont}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxTextBrush}" />
        <Setter Property="Background" Value="{DynamicResource RythmboxElevatedBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RbControlBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RbRadiusControl}" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="MaxWidth" Value="320" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         SCROLL BAR
         ═══════════════════════════════════════════════════════════════ -->
    <Style Selector="ScrollBar">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="ScrollBar /template/ Thumb">
        <Setter Property="Background" Value="{DynamicResource RbControlBorderBrush}" />
        <Setter Property="CornerRadius" Value="2" />
    </Style>

    <Style Selector="ScrollBar /template/ Thumb:pointerover">
        <Setter Property="Background" Value="{DynamicResource RythmboxDimTextBrush}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         ICON PATH (Lucide)
         Canonical, single source of truth for the `icon` class. The Icons.axaml
         geometries are 24x24 stroke-based Lucide outlines, so they render with a
         transparent fill and a rounded stroke — not a solid fill. App/domain
         style sheets must not redefine this; add new modifiers here instead.
         ═══════════════════════════════════════════════════════════════ -->
    <Style Selector="Path.icon">
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
        <Setter Property="Stretch" Value="Uniform" />
        <Setter Property="Fill" Value="Transparent" />
        <Setter Property="Stroke" Value="{DynamicResource RythmboxTextBrush}" />
        <Setter Property="StrokeThickness" Value="2" />
        <Setter Property="StrokeLineCap" Value="Round" />
        <Setter Property="StrokeJoin" Value="Round" />
    </Style>

    <Style Selector="Path.icon.small">
        <Setter Property="Width" Value="13" />
        <Setter Property="Height" Value="13" />
    </Style>

    <Style Selector="Path.icon.dim">
        <Setter Property="Stroke" Value="{DynamicResource RythmboxDimTextBrush}" />
    </Style>

    <Style Selector="Path.icon.accent">
        <Setter Property="Stroke" Value="{DynamicResource RythmboxAccentBrush}" />
    </Style>

    <Style Selector="Path.icon.danger">
        <Setter Property="Stroke" Value="{DynamicResource RythmboxRedBrush}" />
    </Style>

</Styles>
