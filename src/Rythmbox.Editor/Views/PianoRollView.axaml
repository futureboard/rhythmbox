<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Rythmbox.Editor.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1150" d:DesignHeight="560"
             x:Class="Rythmbox.Editor.Views.PianoRollView"
             x:DataType="vm:EditorViewModel">
    <Border Classes="panel regionFill" Padding="0">
        <Grid RowDefinitions="Auto,*">
            <Border Grid.Row="0" Classes="pianoRollToolbar" Padding="10,6">
                <TextBlock Text="PIANO ROLL" Classes="panelHeader" />
            </Border>

            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Grid RowDefinitions="Auto,*" ColumnDefinitions="112,*">
                    <Border Grid.Row="0" Grid.Column="0" Classes="pianoRollCorner" />
                    <ItemsControl Grid.Row="0" Grid.Column="1" ItemsSource="{Binding RulerTicks}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="0" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PianoRollRulerTickViewModel">
                                <Border Width="18" Height="24" Classes="pianoRollRuler" Classes.bar="{Binding IsBarStart}" Classes.beat="{Binding IsBeatStart}">
                                    <TextBlock Text="{Binding Label}" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center" Classes="dim" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ItemsControl Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" ItemsSource="{Binding Lanes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PianoRollLaneViewModel">
                                <Grid ColumnDefinitions="112,*" Classes="pianoRollLane" Classes.alt="{Binding IsAlternateRow}">
                                    <Border Grid.Column="0" Classes="pianoRollLaneHeader" Classes.perc="{Binding IsPerc}">
                                        <Grid ColumnDefinitions="*,Auto" Margin="8,0">
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="1">
                                                <TextBlock Text="{Binding Label}" FontSize="11" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding NoteLabel}" FontSize="9" Classes="dim" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <ItemsControl Grid.Column="1" ItemsSource="{Binding Notes}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="0" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:PianoRollNoteViewModel">
                                                <Button Command="{Binding ToggleCommand}"
                                                        Classes="pianoRollNote"
                                                        Classes.active="{Binding IsActive}"
                                                        Classes.bar="{Binding IsBarStart}"
                                                        Classes.beat="{Binding IsBeatStart}"
                                                        Classes.playing="{Binding IsPlaying}"
                                                        Width="18" Height="24" Padding="0" Margin="0" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
