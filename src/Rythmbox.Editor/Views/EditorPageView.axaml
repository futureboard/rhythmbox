<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Rythmbox.Editor.ViewModels"
             xmlns:views="using:Rythmbox.Editor.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="760"
             x:Class="Rythmbox.Editor.Views.EditorPageView"
             x:DataType="vm:EditorViewModel"
             KeyDown="OnPageKeyDown">

    <Grid RowDefinitions="Auto,*" Margin="14">
        <!-- Command rail replaces the old page header/footer without losing editor controls. -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,12">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                    <TextBlock Text="BPM" Classes="dim" FontSize="9" VerticalAlignment="Center" />
                    <NumericUpDown Minimum="40" Maximum="240" Value="{Binding Bpm}" Width="84" FormatString="0.0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                    <TextBlock Text="BARS" Classes="dim" FontSize="9" VerticalAlignment="Center" />
                    <NumericUpDown Minimum="1" Maximum="8" Value="{Binding Bars}" Width="62" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                    <TextBlock Text="GRID" Classes="dim" FontSize="9" VerticalAlignment="Center" ToolTip.Tip="Steps per bar" />
                    <NumericUpDown Minimum="4" Maximum="32" Increment="4" Value="{Binding StepsPerBar}" Width="62" />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button Command="{Binding NewPatternCommand}" Classes="toolbarBtn">New</Button>
                <Button Command="{Binding BrowseOpenMidiCommand}" Classes="toolbarBtn">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Path Data="{StaticResource IconFolderOpen}" Classes="icon small" />
                        <TextBlock Text="Open…" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding BrowseSaveMidiCommand}" Classes="accent toolbarBtn">
                    <TextBlock Text="Save…" Foreground="{DynamicResource RythmboxOnAccentBrush}" FontWeight="Bold" />
                </Button>
                <Button Command="{Binding ClearPatternCommand}" Classes="toolbarBtn">Clear</Button>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <Button Command="{Binding PlayPreviewCommand}" Classes="transportPlay toolbarBtn"
                        Classes.playing="{Binding IsPlaying}" MinWidth="108">
                    <StackPanel Orientation="Horizontal" Spacing="7" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Path Data="{StaticResource IconPlay}" Width="12" Height="12" Stretch="Uniform"
                              Fill="{Binding $parent[Button].Foreground}" IsVisible="{Binding !IsPlaying}" />
                        <Path Data="{StaticResource IconSquare}" Width="11" Height="11" Stretch="Uniform"
                              Fill="{Binding $parent[Button].Foreground}" IsVisible="{Binding IsPlaying}" />
                        <TextBlock Text="Preview" FontWeight="Bold" Foreground="{Binding $parent[Button].Foreground}" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding StopPreviewCommand}" Classes="toolbarBtn">Stop</Button>
            </StackPanel>
        </Grid>

        <views:PianoRollView Grid.Row="1" />
    </Grid>
</UserControl>
