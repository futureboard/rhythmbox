<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Rythmbox.Editor.ViewModels"
        xmlns:views="using:Rythmbox.Editor.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="760"
        x:Class="Rythmbox.Editor.Views.MainWindow"
        x:DataType="vm:EditorViewModel"
        Title="{Binding Title}"
        Width="1200" Height="760" MinWidth="980" MinHeight="640"
        Background="{DynamicResource RythmboxBackgroundBrush}"
        KeyDown="OnWindowKeyDown">
    <views:EditorPageView Focusable="True" />
</Window>
