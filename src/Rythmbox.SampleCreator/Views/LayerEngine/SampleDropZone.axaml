<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Rythmbox.SampleCreator.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="360" d:DesignHeight="72"
             x:Class="Rythmbox.SampleCreator.Views.LayerEngine.SampleDropZone"
             x:DataType="vm:VelocityLayerViewModel">
    <Border x:Name="Zone" Classes="leDropZone">
        <StackPanel Spacing="6" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Drop WAV files here or click Import WAV"
                       Classes="dim" FontSize="11" HorizontalAlignment="Center"
                       TextAlignment="Center" TextWrapping="Wrap" />
            <Button Command="{Binding Pad.ImportToLayerCommand}" CommandParameter="{Binding}"
                    Classes="toolbarBtn" HorizontalAlignment="Center"
                    ToolTip.Tip="Import a WAV as a new round robin on this layer">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Path Data="{StaticResource IconFolderOpen}" Classes="icon small" />
                    <TextBlock Text="Import WAV" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Border>
</UserControl>
