<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Rythmbox.SampleCreator.ViewModels"
             xmlns:views="using:Rythmbox.SampleCreator.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="760"
             x:Class="Rythmbox.SampleCreator.Views.SampleCreatorPageView"
             x:DataType="vm:SampleCreatorViewModel"
             Focusable="True"
             KeyDown="OnPageKeyDown">

    <Grid RowDefinitions="Auto,*" Margin="16">
        <!-- Compact command rail: avoids a second page header/footer under the app shell. -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,*" Margin="0,0,0,12">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="KIT" Classes="dim" FontSize="9" FontWeight="Bold" LetterSpacing="1" VerticalAlignment="Center" />
                <TextBox Text="{Binding KitName}" PlaceholderText="Kit name" Width="260" Classes="kitNameField" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button Command="{Binding NewKitCommand}" Classes="toolbarBtn">New Kit</Button>
                <Button Command="{Binding BrowseOpenPresetCommand}" Classes="toolbarBtn">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Path Data="{StaticResource IconFolderOpen}" Classes="icon small" />
                        <TextBlock Text="Open…" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding BrowseSaveKitCommand}" Classes="accent toolbarBtn">
                    <TextBlock Text="Save Kit…" Foreground="{DynamicResource RythmboxOnAccentBrush}" FontWeight="Bold" />
                </Button>
            </StackPanel>
            <TextBlock Grid.Column="2" Text="{Binding StatusText}" Classes="dim" FontSize="10"
                       HorizontalAlignment="Right" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="360" />
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="292,*,308" ColumnSpacing="12">
            <!-- Battery-style pad matrix: selection is the main navigation action. -->
            <Border Grid.Column="0" Classes="panel kitPadBrowser" Padding="10">
                <DockPanel LastChildFill="True">
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                        <StackPanel Spacing="2">
                            <TextBlock Text="PAD MATRIX" Classes="dim" FontSize="9" FontWeight="Bold" LetterSpacing="1" />
                            <TextBlock Text="DRUM CELLS" Classes="panelHeader" />
                        </StackPanel>
                        <Border Grid.Column="1" Classes="kitCountBadge" VerticalAlignment="Center">
                            <TextBlock Text="GM" FontSize="9" FontWeight="Bold" />
                        </Border>
                    </Grid>

                    <TextBlock DockPanel.Dock="Bottom" Text="Select a cell, then import a WAV or drag a batch to fill consecutive pads."
                               Classes="dim" FontSize="10" TextWrapping="Wrap" Margin="0,10,0,0" />

                    <ListBox ItemsSource="{Binding Pads}" SelectedItem="{Binding SelectedPad}"
                             Classes="kitPadMatrix">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4" HorizontalAlignment="Stretch" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerTheme>
                            <ControlTheme TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                            </ControlTheme>
                        </ListBox.ItemContainerTheme>
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:PadSampleViewModel">
                                <Border Classes="kitPadCell"
                                        Classes.hasAudio="{Binding HasAudio}"
                                        Classes.selected="{Binding IsSelected}">
                                    <Grid RowDefinitions="Auto,*" ColumnDefinitions="Auto,*">
                                        <Ellipse Grid.Row="0" Grid.Column="0" Width="5" Height="5" Margin="0,2,5,0"
                                                 Fill="{DynamicResource RythmboxGreenBrush}" IsVisible="{Binding HasAudio}" />
                                        <Ellipse Grid.Row="0" Grid.Column="0" Width="5" Height="5" Margin="0,2,5,0"
                                                 Fill="{DynamicResource RythmboxBorderBrush}" IsVisible="{Binding !HasAudio}" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Label}" Classes="kitPadLabel"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DurationLabel}" Classes="dim"
                                                   FontSize="8" Margin="0,3,0,0" TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Kontakt-style sample editor. All existing layer and RR bindings stay intact. -->
            <Border Grid.Column="1" Classes="kitEditorEmpty"
                    IsVisible="{Binding SelectedPad, Converter={x:Static ObjectConverters.IsNull}}">
                <StackPanel Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24">
                    <TextBlock Text="Select a pad cell" FontSize="16" FontWeight="Medium" HorizontalAlignment="Center" />
                    <TextBlock Text="Choose a pad from the matrix to load a sample, shape its sound, or build velocity layers."
                               Classes="dim" FontSize="12" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="340" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Classes="kitEditor"
                    IsVisible="{Binding SelectedPad, Converter={x:Static ObjectConverters.IsNotNull}}">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="12" DataContext="{Binding SelectedPad}" Margin="0,0,4,0">
                        <Border Classes="kitSelectedHeader">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <Border Grid.Column="0" Classes="kitPadNumber">
                                    <TextBlock Text="{Binding Label}" FontWeight="Bold" FontSize="12" />
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="SELECTED PAD" Classes="dim" FontSize="9" FontWeight="Bold" LetterSpacing="1" />
                                    <TextBlock Text="{Binding FileName}" FontWeight="Medium" FontSize="13" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding SelectionLabel}" Classes="dim" FontSize="9" TextAlignment="Right" />
                                    <TextBlock Text="{Binding SampleRateLabel}" Classes="mono dim" FontSize="10" HorizontalAlignment="Right" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Classes="kitWaveformFrame">
                            <DockPanel LastChildFill="True">
                                <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                                    <TextBlock Text="SAMPLE VIEW" Classes="panelHeader" />
                                    <TextBlock Grid.Column="1" Text="{Binding DurationLabel}" Classes="mono dim" FontSize="10" />
                                </Grid>
                                <views:WaveformView DataContext="{Binding}" Height="190" />
                            </DockPanel>
                        </Border>

                        <Border Classes="kitParamDeck">
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="12">
                                    <StackPanel Grid.Column="0" Spacing="5" HorizontalAlignment="Center">
                                        <TextBlock Text="TRIM START" Classes="dim" FontSize="9" HorizontalAlignment="Center" />
                                        <views:RotaryKnobView Minimum="0" Maximum="1" DefaultValue="0"
                                                              Value="{Binding TrimStart, Mode=TwoWay}" HorizontalAlignment="Center" />
                                        <TextBlock Text="{Binding TrimStart, StringFormat={}{0:0.000}}" Classes="mono" FontSize="10" HorizontalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="5" HorizontalAlignment="Center">
                                        <TextBlock Text="TRIM END" Classes="dim" FontSize="9" HorizontalAlignment="Center" />
                                        <views:RotaryKnobView Minimum="0" Maximum="1" DefaultValue="1"
                                                              Value="{Binding TrimEnd, Mode=TwoWay}" HorizontalAlignment="Center" />
                                        <TextBlock Text="{Binding TrimEnd, StringFormat={}{0:0.000}}" Classes="mono" FontSize="10" HorizontalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Spacing="5" HorizontalAlignment="Center">
                                        <TextBlock Text="GAIN" Classes="dim" FontSize="9" HorizontalAlignment="Center" />
                                        <views:RotaryKnobView Minimum="0" Maximum="2" DefaultValue="1"
                                                              Value="{Binding Gain, Mode=TwoWay}" HorizontalAlignment="Center" />
                                        <TextBlock Text="{Binding GainLabel}" Classes="mono" FontSize="10" HorizontalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" Spacing="5" HorizontalAlignment="Center">
                                        <TextBlock Text="PITCH" Classes="dim" FontSize="9" HorizontalAlignment="Center" />
                                        <views:RotaryKnobView Minimum="-12" Maximum="12" DefaultValue="0"
                                                              Value="{Binding Pitch, Mode=TwoWay}" HorizontalAlignment="Center" />
                                        <TextBlock Text="{Binding PitchLabel}" Classes="mono" FontSize="10" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6">
                                    <Button Command="{Binding ApplyTrimCommand}" Classes="toolbarBtn">Apply Trim</Button>
                                    <Button Command="{Binding ApplyPitchCommand}" Classes="toolbarBtn">Apply Pitch</Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Classes="kitLayerPanel">
                            <DockPanel LastChildFill="True">
                                <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,10">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="LAYER ENGINE" Classes="dim" FontSize="9" FontWeight="Bold" LetterSpacing="1" />
                                        <TextBlock Text="VELOCITY / ROUND ROBIN" Classes="panelHeader" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Command="{Binding AddLayerCommand}" Classes="toolbarBtn" Margin="0,0,6,0">Add Layer</Button>
                                    <Button Grid.Column="2" Command="{Binding AddRoundRobinCommand}" Classes="toolbarBtn">Add RR</Button>
                                </Grid>

                                <TextBlock DockPanel.Dock="Top" Text="Create velocity zones, then load alternate samples for natural repetition."
                                           Classes="dim" FontSize="10" Margin="0,0,0,10" IsVisible="{Binding !HasVelocityLayers}" />

                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10" MinHeight="168" IsVisible="{Binding HasVelocityLayers}">
                                    <Border Grid.Column="0" Classes="kitLayerList">
                                        <DockPanel LastChildFill="True">
                                            <TextBlock DockPanel.Dock="Top" Text="VELOCITY ZONES" Classes="dim" FontSize="9" FontWeight="Bold" Margin="0,0,0,6" />
                                            <ListBox ItemsSource="{Binding Layers}" SelectedItem="{Binding SelectedLayer}">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:VelocityLayerViewModel">
                                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                                                            <StackPanel Spacing="2">
                                                                <TextBlock Text="{Binding Summary}" FontWeight="Medium" FontSize="10" />
                                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                                    <NumericUpDown Minimum="1" Maximum="127" Increment="1" Value="{Binding VelocityLow, Mode=TwoWay}" Width="56" FormatString="0" />
                                                                    <TextBlock Text="–" VerticalAlignment="Center" Classes="dim" />
                                                                    <NumericUpDown Minimum="1" Maximum="127" Increment="1" Value="{Binding VelocityHigh, Mode=TwoWay}" Width="56" FormatString="0" />
                                                                </StackPanel>
                                                            </StackPanel>
                                                            <Button Grid.Column="1" Command="{Binding RemoveCommand}" Content="×" Classes="toolbarBtn" Padding="7,2" VerticalAlignment="Top" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </DockPanel>
                                    </Border>

                                    <Border Grid.Column="1" Classes="kitLayerList">
                                        <DockPanel LastChildFill="True">
                                            <TextBlock DockPanel.Dock="Top" Text="ROUND ROBINS" Classes="dim" FontSize="9" FontWeight="Bold" Margin="0,0,0,6" />
                                            <ListBox ItemsSource="{Binding SelectedLayer.RoundRobins}" SelectedItem="{Binding SelectedRoundRobin}">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:RoundRobinSlotViewModel">
                                                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                                                            <StackPanel Spacing="1">
                                                                <TextBlock Text="{Binding DisplayName}" FontWeight="Medium" FontSize="10" TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Text="{Binding DurationLabel}" Classes="dim" FontSize="9" />
                                                            </StackPanel>
                                                            <Button Grid.Column="1" Command="{Binding PreviewCommand}" Content="▶" Classes="toolbarBtn" Padding="7,2" />
                                                            <Button Grid.Column="2" Command="{Binding RemoveCommand}" Content="×" Classes="toolbarBtn" Padding="7,2" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </DockPanel>
                                    </Border>
                                </Grid>
                            </DockPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Kontakt-inspired focused inspector: all actions stay within the selected-pad context. -->
            <Border Grid.Column="2" Classes="kitInspector">
                <StackPanel Spacing="10">
                        <StackPanel Spacing="2">
                            <TextBlock Text="PAD INSPECTOR" Classes="dim" FontSize="9" FontWeight="Bold" LetterSpacing="1" />
                            <TextBlock Text="QUICK ACTIONS" Classes="panelHeader" />
                        </StackPanel>
                        <Border Classes="kitInspectorReadout" DataContext="{Binding SelectedPad}">
                            <StackPanel Spacing="3">
                                <TextBlock Text="SELECTED" Classes="dim" FontSize="9" />
                                <TextBlock Text="{Binding Label}" FontSize="15" FontWeight="Bold" />
                                <TextBlock Text="{Binding FileName}" Classes="dim" FontSize="10" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>
                        <Button Command="{Binding BrowseImportWavCommand}" HorizontalAlignment="Stretch" Classes="accent kitImport">
                            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                <Path Data="{StaticResource IconFolderOpen}" Classes="icon small" />
                                <TextBlock Text="Import WAV" FontWeight="Bold" Foreground="{DynamicResource RythmboxOnAccentBrush}" />
                            </StackPanel>
                        </Button>
                        <StackPanel Spacing="7" DataContext="{Binding SelectedPad}">
                            <Button Command="{Binding PreviewCommand}" HorizontalAlignment="Stretch" Classes="transportPlay">
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                    <Path Data="{StaticResource IconPlay}" Width="12" Height="12" Stretch="Uniform" Fill="{Binding $parent[Button].Foreground}" />
                                    <TextBlock Text="Preview Pad" FontWeight="Bold" Foreground="{Binding $parent[Button].Foreground}" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding NormalizeCommand}" HorizontalAlignment="Stretch" Classes="secondary">Normalize</Button>
                            <Button Command="{Binding AddLayerCommand}" HorizontalAlignment="Stretch" Classes="secondary">Create Velocity Layer</Button>
                            <Button Command="{Binding AddRoundRobinCommand}" HorizontalAlignment="Stretch" Classes="secondary">Add Round Robin</Button>
                            <Button Command="{Binding ClearCommand}" HorizontalAlignment="Stretch" Classes="danger" Margin="0,6,0,0">Clear Sample</Button>
                        </StackPanel>
                        <Border BorderBrush="{DynamicResource RythmboxPanelBorderBrush}" BorderThickness="0,1,0,0" Padding="0,10,0,0" Margin="0,2,0,0">
                            <Button Command="{Binding ResetAllPitchCommand}" HorizontalAlignment="Stretch" Classes="secondary">Reset Pitch on Kit</Button>
                        </Border>
                    <TextBlock Text="Import replaces the selected round robin when a velocity layer is active; otherwise it replaces this pad’s single sample."
                               Classes="dim" TextWrapping="Wrap" Margin="0,4,0,0" FontSize="10" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
