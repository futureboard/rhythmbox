<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Rythmbox.SampleCreator.ViewModels"
             xmlns:views="using:Rythmbox.SampleCreator.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="760"
             x:Class="Rythmbox.SampleCreator.Views.SampleCreatorPageView"
             x:DataType="vm:SampleCreatorViewModel"
             Focusable="True"
             KeyDown="OnPageKeyDown">

    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top" Classes="headerBar" Padding="14,10">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Path Data="{StaticResource IconAudioLines}" Classes="icon accent small" />
                    <TextBlock Text="KIT BUILDER" FontWeight="Bold" FontSize="14"
                               Foreground="{DynamicResource RythmboxAccentBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <Button Command="{Binding NewKitCommand}" Classes="toolbarBtn">New Kit</Button>
                    <Button Command="{Binding BrowseOpenPresetCommand}" Classes="toolbarBtn">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Path Data="{StaticResource IconFolderOpen}" Classes="icon small" />
                            <TextBlock Text="Open Preset…" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding BrowseSaveKitCommand}" Classes="accent toolbarBtn">
                        <TextBlock Text="Save Kit…" Foreground="{DynamicResource RythmboxOnAccentBrush}" FontWeight="Bold" />
                    </Button>
                </StackPanel>

                <TextBox Grid.Column="2" Text="{Binding KitName}" PlaceholderText="Kit name" MinWidth="200" />
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom" Classes="footerBar" Margin="14,0,14,14">
            <TextBlock Text="{Binding StatusText}" Classes="dim" FontSize="11" />
        </Border>

        <Grid ColumnDefinitions="220,*,300" Margin="14">
            <Border Grid.Column="0" Classes="panel" Margin="0,0,10,0">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top" Text="PADS" Classes="panelHeader" Margin="0,0,0,8" />
                    <ListBox ItemsSource="{Binding Pads}" SelectedItem="{Binding SelectedPad}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:PadSampleViewModel">
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                    <Ellipse Grid.Column="0" Width="6" Height="6" VerticalAlignment="Center"
                                             Fill="{DynamicResource RythmboxGreenBrush}"
                                             IsVisible="{Binding HasAudio}" />
                                    <Ellipse Grid.Column="0" Width="6" Height="6" VerticalAlignment="Center"
                                             Fill="{DynamicResource RythmboxBorderBrush}"
                                             IsVisible="{Binding !HasAudio}" />
                                    <TextBlock Grid.Column="1" Text="{Binding Label}" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="2" Text="{Binding DurationLabel}" Classes="dim" FontSize="10" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Classes="panel" Margin="0,0,10,0"
                    IsVisible="{Binding SelectedPad, Converter={x:Static ObjectConverters.IsNull}}">
                <StackPanel Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24">
                    <TextBlock Text="Select a pad" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center" />
                    <TextBlock Text="Choose a pad on the left, then import or drop a WAV to assign a sample."
                               Classes="dim" FontSize="12" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="320" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Classes="panel" Margin="0,0,10,0" IsVisible="{Binding SelectedPad, Converter={x:Static ObjectConverters.IsNotNull}}">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="12" DataContext="{Binding SelectedPad}" Margin="0,0,8,0">
                        <TextBlock Text="{Binding Label}" FontSize="18" FontWeight="Bold" />
                        <TextBlock Text="{Binding FileName}" Classes="dim" FontSize="12" />
                        <TextBlock Text="{Binding SelectionLabel}" Classes="mono dim" FontSize="11" />
                        <TextBlock Text="{Binding SampleRateLabel}" Classes="mono dim" FontSize="11"
                                   IsVisible="{Binding HasAudio}" />
                        <views:WaveformView DataContext="{Binding}" Height="140" />

                        <Grid ColumnDefinitions="*,*,Auto" ColumnSpacing="20" Margin="0,4,0,0">
                            <StackPanel Grid.Column="0" Spacing="6" HorizontalAlignment="Center">
                                <TextBlock Text="TRIM START" Classes="dim" FontSize="10" HorizontalAlignment="Center" />
                                <views:RotaryKnobView Minimum="0" Maximum="1" DefaultValue="0"
                                                      Value="{Binding TrimStart, Mode=TwoWay}"
                                                      HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding TrimStart, StringFormat={}{0:0.000}}" Classes="mono" FontSize="10" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="6" HorizontalAlignment="Center">
                                <TextBlock Text="TRIM END" Classes="dim" FontSize="10" HorizontalAlignment="Center" />
                                <views:RotaryKnobView Minimum="0" Maximum="1" DefaultValue="1"
                                                      Value="{Binding TrimEnd, Mode=TwoWay}"
                                                      HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding TrimEnd, StringFormat={}{0:0.000}}" Classes="mono" FontSize="10" HorizontalAlignment="Center" />
                            </StackPanel>
                            <Button Grid.Column="2" Command="{Binding ApplyTrimCommand}" Content="Apply trim"
                                    Classes="toolbarBtn" VerticalAlignment="Center" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*,Auto" ColumnSpacing="20" Margin="0,8,0,0">
                            <StackPanel Grid.Column="0" Spacing="6" HorizontalAlignment="Center">
                                <TextBlock Text="GAIN" Classes="dim" FontSize="10" HorizontalAlignment="Center" />
                                <views:RotaryKnobView Minimum="0" Maximum="2" DefaultValue="1"
                                                      Value="{Binding Gain, Mode=TwoWay}"
                                                      HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding GainLabel}" Classes="mono" FontSize="10" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="6" HorizontalAlignment="Center">
                                <TextBlock Text="PITCH" Classes="dim" FontSize="10" HorizontalAlignment="Center" />
                                <views:RotaryKnobView Minimum="-12" Maximum="12" DefaultValue="0"
                                                      Value="{Binding Pitch, Mode=TwoWay}"
                                                      HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding PitchLabel}" Classes="mono" FontSize="10" HorizontalAlignment="Center" />
                            </StackPanel>
                            <Button Grid.Column="2" Command="{Binding ApplyPitchCommand}" Content="Apply pitch"
                                    Classes="toolbarBtn" VerticalAlignment="Center" />
                        </Grid>

                        <Border BorderBrush="{DynamicResource RythmboxPanelBorderBrush}" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,8,0,0">
                            <DockPanel LastChildFill="True">
                                <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,8">
                                    <TextBlock Text="VELOCITY LAYERS" Classes="panelHeader" VerticalAlignment="Center" />
                                    <Button Grid.Column="1" Command="{Binding AddLayerCommand}" Content="Add Layer"
                                            Classes="toolbarBtn" Margin="0,0,6,0" />
                                    <Button Grid.Column="2" Command="{Binding AddRoundRobinCommand}" Content="Add RR"
                                            Classes="toolbarBtn" />
                                </Grid>

                                <TextBlock DockPanel.Dock="Top"
                                           Text="No velocity layers yet — Add Layer"
                                           Classes="dim" FontSize="12" Margin="0,0,0,8"
                                           IsVisible="{Binding !HasVelocityLayers}" />

                                <Grid ColumnDefinitions="220,*" ColumnSpacing="10" MinHeight="180"
                                      IsVisible="{Binding HasVelocityLayers}">
                                    <Border Grid.Column="0" Classes="panel" Padding="6">
                                        <DockPanel LastChildFill="True">
                                            <TextBlock DockPanel.Dock="Top" Text="LAYERS" Classes="dim" FontSize="10" Margin="0,0,0,6" />
                                            <ListBox ItemsSource="{Binding Layers}"
                                                     SelectedItem="{Binding SelectedLayer}">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:VelocityLayerViewModel">
                                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                                                            <StackPanel Spacing="2">
                                                                <TextBlock Text="{Binding Summary}" FontWeight="SemiBold" FontSize="11" />
                                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                                    <NumericUpDown Minimum="1" Maximum="127" Increment="1"
                                                                                   Value="{Binding VelocityLow, Mode=TwoWay}"
                                                                                   Width="64" FormatString="0" />
                                                                    <TextBlock Text="–" VerticalAlignment="Center" Classes="dim" />
                                                                    <NumericUpDown Minimum="1" Maximum="127" Increment="1"
                                                                                   Value="{Binding VelocityHigh, Mode=TwoWay}"
                                                                                   Width="64" FormatString="0" />
                                                                </StackPanel>
                                                            </StackPanel>
                                                            <Button Grid.Column="1" Command="{Binding RemoveCommand}"
                                                                    Content="×" Classes="toolbarBtn" Padding="8,2"
                                                                    VerticalAlignment="Top" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </DockPanel>
                                    </Border>

                                    <Border Grid.Column="1" Classes="panel" Padding="6">
                                        <DockPanel LastChildFill="True">
                                            <TextBlock DockPanel.Dock="Top" Text="ROUND ROBIN" Classes="dim" FontSize="10" Margin="0,0,0,6" />
                                            <ListBox ItemsSource="{Binding SelectedLayer.RoundRobins}"
                                                     SelectedItem="{Binding SelectedRoundRobin}">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:RoundRobinSlotViewModel">
                                                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                                                            <StackPanel Spacing="1">
                                                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="11"
                                                                           TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Text="{Binding DurationLabel}" Classes="dim" FontSize="10" />
                                                            </StackPanel>
                                                            <Button Grid.Column="1" Command="{Binding PreviewCommand}"
                                                                    Content="▶" Classes="toolbarBtn" Padding="8,2" />
                                                            <Button Grid.Column="2" Command="{Binding RemoveCommand}"
                                                                    Content="×" Classes="toolbarBtn" Padding="8,2" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </DockPanel>
                                    </Border>
                                </Grid>
                            </DockPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2" Classes="panel">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top" Text="INSPECTOR" Classes="panelHeader" Margin="0,0,0,10" />
                    <TextBlock DockPanel.Dock="Bottom"
                               Text="Select a velocity layer and round-robin slot to edit its waveform. Import replaces the selected RR (or the single sample)."
                               Classes="dim" TextWrapping="Wrap" Margin="0,12,0,0" FontSize="11" />
                    <StackPanel Spacing="8">
                        <Button Command="{Binding BrowseImportWavCommand}" HorizontalAlignment="Stretch" Classes="accent">
                            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                <Path Data="{StaticResource IconFolderOpen}" Classes="icon small" />
                                <TextBlock Text="Import WAV" FontWeight="Bold"
                                           Foreground="{DynamicResource RythmboxOnAccentBrush}" />
                            </StackPanel>
                        </Button>
                        <StackPanel Spacing="8" DataContext="{Binding SelectedPad}">
                            <Button Command="{Binding PreviewCommand}" HorizontalAlignment="Stretch" Classes="transportPlay">
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                    <Path Data="{StaticResource IconPlay}" Width="12" Height="12" Stretch="Uniform"
                                          Fill="{DynamicResource RythmboxOnAccentBrush}" />
                                    <TextBlock Text="Preview Pad" FontWeight="Bold"
                                               Foreground="{DynamicResource RythmboxOnAccentBrush}" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding NormalizeCommand}" HorizontalAlignment="Stretch" Classes="secondary">Normalize</Button>
                            <Button Command="{Binding AddLayerCommand}" HorizontalAlignment="Stretch" Classes="secondary">Add Velocity Layer</Button>
                            <Button Command="{Binding AddRoundRobinCommand}" HorizontalAlignment="Stretch" Classes="secondary">Add Round Robin</Button>
                            <Button Command="{Binding ClearCommand}" HorizontalAlignment="Stretch" Classes="danger" Margin="0,8,0,0">Clear Sample</Button>
                        </StackPanel>
                        <Button Command="{Binding ResetAllPitchCommand}" HorizontalAlignment="Stretch" Classes="secondary">Reset Pitch</Button>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
