<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Rythmbox.App.ViewModels"
             mc:Ignorable="d" d:DesignWidth="650" d:DesignHeight="320"
             x:Class="Rythmbox.App.Views.PercussionPadGridView"
             x:DataType="vm:MainWindowViewModel">
    <Border Classes="region regionFill" Padding="14">
        <DockPanel LastChildFill="True">
            <Border DockPanel.Dock="Top" BorderBrush="{DynamicResource RythmboxPanelBorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,10" Margin="0,0,0,10">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="PERFORM" Classes="dim" FontSize="9" FontWeight="Bold" LetterSpacing="1" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Localization.DrumPadsTitle}" Classes="panelHeader" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Localization.DrumPadsVoices}" Classes="dim" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <TextBlock Text="{Binding PadGrid.PageNoteRange}" Classes="mono dim" FontSize="10" VerticalAlignment="Center" />
                        <Button Command="{Binding PadGrid.PreviousPageCommand}" Classes="toolbarBtn" Padding="8,4"
                                IsEnabled="{Binding PadGrid.CanGoToPreviousPage}" Content="◀" />
                        <TextBlock Text="{Binding PadGrid.PageLabel}" Classes="mono" FontSize="11" VerticalAlignment="Center" MinWidth="44" TextAlignment="Center" />
                        <Button Command="{Binding PadGrid.NextPageCommand}" Classes="toolbarBtn" Padding="8,4"
                                IsEnabled="{Binding PadGrid.CanGoToNextPage}" Content="▶" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid ColumnDefinitions="*,156" ColumnSpacing="12">
                <ItemsControl Grid.Column="0"
                              ItemsSource="{Binding PadGrid.CurrentPagePads}"
                              HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4" Rows="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerTheme>
                        <ControlTheme TargetType="ContentPresenter">
                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                            <Setter Property="VerticalAlignment" Value="Stretch" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="VerticalContentAlignment" Value="Stretch" />
                        </ControlTheme>
                    </ItemsControl.ItemContainerTheme>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:PadViewModel">
                            <Button Command="{Binding HitCommand}" Padding="0"
                                    IsEnabled="{Binding Config.IsEnabled}"
                                    IsVisible="{Binding !IsPlaceholder}"
                                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"
                                    MinHeight="0"
                                    Classes="pad"
                                    Classes.used="{Binding IsUsedInLoop}"
                                    Classes.hovered="{Binding IsHovered}"
                                    Classes.mouseDown="{Binding IsMouseDown}"
                                    Classes.hit="{Binding IsHitFlashing}"
                                    Classes.playing="{Binding IsPlaying}"
                                    Classes.selected="{Binding IsSelected}"
                                    Classes.editing="{Binding IsEditing}"
                                    Classes.assigned="{Binding IsAssigned}"
                                    Classes.empty="{Binding !IsAssigned}"
                                    ToolTip.Tip="{Binding NoteDetail}"
                                    PointerEntered="OnPadPointerEntered"
                                    PointerExited="OnPadPointerExited"
                                    PointerPressed="OnPadPointerPressed"
                                    PointerReleased="OnPadPointerReleased"
                                    PointerCaptureLost="OnPadPointerCaptureLost">
                                <StackPanel Spacing="2" VerticalAlignment="Center" Margin="6,8">
                                    <TextBlock Text="{Binding Label}" Classes="padLabel" HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding SampleDetail}" Classes="padNumber" HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding OutputLabel}" Classes="dim" FontSize="8" HorizontalAlignment="Center" />
                                    <Ellipse Width="5" Height="5" HorizontalAlignment="Center" Margin="0,2,0,0"
                                             Classes="padSampleDot"
                                             Classes.hasSample="{Binding HasSample}" />
                                    <TextBlock Text="{Binding DebugPadInspector}" Classes="mono dim" FontSize="7"
                                               TextWrapping="Wrap" IsVisible="{Binding IsDebugPadInspectorVisible}" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Grid.Column="1" Classes="panel hotloadRack" Padding="10">
                    <DockPanel LastChildFill="True">
                        <StackPanel DockPanel.Dock="Top" Spacing="2" Margin="0,0,0,8">
                            <TextBlock Text="KIT SLOTS" Classes="panelHeader" FontSize="10" />
                            <TextBlock Text="ASSIGN / RECALL" Classes="dim" FontSize="9" />
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding KitBrowser.HotloadSlots}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="4" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerTheme>
                                <ControlTheme TargetType="ContentPresenter">
                                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                                    <Setter Property="VerticalAlignment" Value="Stretch" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                </ControlTheme>
                            </ItemsControl.ItemContainerTheme>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:KitHotloadSlotViewModel">
                                    <Button Command="{Binding ActivateCommand}"
                                            ToolTip.Tip="{Binding ToolTip}"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            VerticalContentAlignment="Stretch"
                                            Padding="6,8"
                                            Margin="0,0,0,6"
                                            Classes="hotloadSlot"
                                            Classes.empty="{Binding IsEmpty}"
                                            Classes.active="{Binding IsActive}">
                                        <Button.ContextFlyout>
                                            <MenuFlyout>
                                                <MenuItem Header="Change kit…" Command="{Binding ChangeCommand}" />
                                                <MenuItem Header="Clear slot" Command="{Binding ClearCommand}" />
                                            </MenuFlyout>
                                        </Button.ContextFlyout>
                                        <Grid ColumnDefinitions="32,*" RowDefinitions="Auto,Auto">
                                            <TextBlock Grid.Row="0" Grid.Column="0" Grid.RowSpan="2"
                                                       Text="{Binding SlotName}" FontSize="18" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding KitLabel}"
                                                       Classes="hotloadSlotLabel" TextWrapping="Wrap"
                                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Bottom" />
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="Click to assign"
                                                       Classes="hotloadSlotHint" IsVisible="{Binding IsEmpty}" />
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>
                </Border>
            </Grid>
        </DockPanel>
    </Border>
</UserControl>
