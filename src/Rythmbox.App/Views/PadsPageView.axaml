<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Rythmbox.App.ViewModels"
             xmlns:views="using:Rythmbox.App.Views"
             mc:Ignorable="d" d:DesignWidth="1150" d:DesignHeight="720"
             x:Class="Rythmbox.App.Views.PadsPageView"
             x:DataType="vm:MainWindowViewModel">
    <!-- Pads mode: assignment + audition focus (Machine keeps arranger/style bank). -->
    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0" Classes="region regionBottom" Padding="12,8">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="2">
                    <TextBlock Text="PADS" Classes="panelHeader" />
                    <TextBlock Classes="dim" FontSize="11" TextWrapping="Wrap">
                        Audition and assign kit samples. Use Machine for styles, patterns, and performance.
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="Kit:" Classes="dim" FontSize="10" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Machine.KitLabel}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="Device:" Classes="dim" FontSize="10" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Machine.DeviceLabel}" FontSize="11" VerticalAlignment="Center"
                                       MaxWidth="180" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Command="{Binding KitBrowser.BrowseLoadKitCommand}" Padding="10,6" Classes="accent">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Path Data="{StaticResource IconFolderOpen}" Classes="icon small" />
                            <TextBlock Text="{Binding KitBrowser.LoadButtonLabel}" FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource RythmboxOnAccentBrush}" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:AppPage.Macro}"
                            Padding="10,6" Classes="secondary">
                        <TextBlock Text="Open Kit Builder" FontSize="11" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        <views:PercussionPadGridView Grid.Row="1" />
    </Grid>
</UserControl>
