<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Rythmbox.App.ViewModels"
             xmlns:views="using:Rythmbox.App.Views"
             mc:Ignorable="d" d:DesignWidth="1150" d:DesignHeight="720"
             x:Class="Rythmbox.App.Views.PadsPageView"
             x:DataType="vm:MainWindowViewModel">
    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0" Classes="region regionBottom" Padding="8">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="2">
                    <TextBlock Text="DRUM PADS / KIT" Classes="panelHeader" />
                    <TextBlock Classes="dim">
                        <Run Text="Kit:" />
                        <Run Text="{Binding Machine.KitLabel}" FontWeight="SemiBold" />
                    </TextBlock>
                </StackPanel>
                <Button Grid.Column="1" Click="OnLoadKitClick" Padding="8,4" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Path Data="{StaticResource IconFolderOpen}" Classes="icon small" />
                        <TextBlock Text="{Binding KitBrowser.LoadButtonLabel}" FontSize="11" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
        <views:PercussionPadGridView Grid.Row="1" />
    </Grid>
</UserControl>
