<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Rythmbox.App.ViewModels"
             mc:Ignorable="d" d:DesignWidth="320" d:DesignHeight="150"
             x:Class="Rythmbox.App.Views.NowPlayingView"
             x:DataType="vm:MainWindowViewModel">
    <Border Classes="nowPlaying">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto">

            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding NowPlaying.IndexLabel}" Classes="nowPlayingDim" />
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding NowPlaying.StatusLabel}" Classes="nowPlayingDim" FontWeight="Bold" />

            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="8" Margin="0,4">
                <Button Content="&#8722;" Width="26" Height="26" Padding="0" Command="{Binding NowPlaying.PreviousCommand}" />
                <TextBlock Text="{Binding NowPlaying.LoopName}" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" Foreground="White" />
                <Button Content="+" Width="26" Height="26" Padding="0" Command="{Binding NowPlaying.NextCommand}" />
            </StackPanel>

            <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding NowPlaying.BpmLabel}"
                       FontSize="34" FontWeight="Bold" Foreground="White" Margin="0,2" />

            <ProgressBar Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Classes="nowPlayingProgress"
                         Minimum="0" Maximum="1" Value="{Binding NowPlaying.ProgressFraction}" Margin="0,6,0,0" />

        </Grid>
    </Border>
</UserControl>
