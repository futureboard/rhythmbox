<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Rythmbox.App.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1150" d:DesignHeight="44"
             x:Class="Rythmbox.App.Views.HeaderView"
             x:DataType="vm:MainWindowViewModel">
    <Border Classes="headerBar">
        <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto">

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Path Data="{StaticResource IconDrum}" Classes="icon accent small" />
                <TextBlock Text="RYTHMBOX" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource RythmboxAccentBrush}" VerticalAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="24,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding ClockText}" Classes="mono" FontSize="14" VerticalAlignment="Center" />
                <TextBlock Text="CLOCK" Classes="dim" VerticalAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <Border Classes="badge">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <Path Data="{StaticResource IconAudioLines}" Classes="icon accent small" Width="12" Height="12" />
                        <TextBlock Text="AUDIO" FontSize="11" FontWeight="Bold" />
                    </StackPanel>
                </Border>
                <Button Click="OnLoadSoundFontClick" MaxWidth="220">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Path Data="{StaticResource IconFolderOpen}" Classes="icon small" />
                        <TextBlock Text="{Binding SoundFontBrowser.LoadButtonLabel}" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="10" Margin="16,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="TEMPO" Classes="dim" VerticalAlignment="Center" />
                <TextBlock Text="{Binding NowPlaying.BpmLabel}" Classes="mono" FontSize="15" VerticalAlignment="Center" />
            </StackPanel>

        </Grid>
    </Border>
</UserControl>
