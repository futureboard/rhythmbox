<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Rythmbox.App.ViewModels"
             xmlns:views="using:Rythmbox.App.Views"
             mc:Ignorable="d" d:DesignWidth="1150" d:DesignHeight="44"
             x:Class="Rythmbox.App.Views.HeaderView"
             x:DataType="vm:MainWindowViewModel">
    <!--
      Slim global header — always-needed controls only.
      Style/Pattern live on Machine/Home. Scan/Sub/Fullscreen live in overflow.
    -->
    <Border Classes="headerBar">
        <Grid ColumnDefinitions="Auto,*,Auto" MinHeight="38">

            <!-- Left: logo + mode -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="0,0,16,0">
                <views:LogoView Height="12" VerticalAlignment="Center" Width="96" />
                <Border Classes="headerDivider" />
                <StackPanel Spacing="0" VerticalAlignment="Center">
                    <TextBlock Text="WORKSTATION" Classes="dim" FontSize="8" FontWeight="Medium" LetterSpacing="1" />
                    <TextBlock Text="{Binding CurrentPageTitle}" FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource RythmboxAccentBrush}"
                               MaxWidth="108" TextTrimming="CharacterEllipsis"
                               ToolTip.Tip="{Binding CurrentPageTitle}" />
                </StackPanel>
            </StackPanel>

            <!-- Center: transport + tempo + tap + timer -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button Command="{Binding Player.PlayPauseCommand}"
                        Classes="transportPlay"
                        Classes.playing="{Binding Player.IsPlaying}"
                        ToolTip.Tip="{Binding Localization.TransportPlayTip}"
                        MinWidth="32" Padding="8,3">
                    <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                        <Path Data="{StaticResource IconSquare}" Width="10" Height="10" Stretch="Uniform"
                              Fill="{Binding $parent[Button].Foreground}"
                              IsVisible="{Binding Player.IsPlaying}" />
                        <Path Data="{StaticResource IconPlay}" Width="10" Height="10" Stretch="Uniform"
                              Fill="{Binding $parent[Button].Foreground}"
                              IsVisible="{Binding !Player.IsPlaying}" />
                        <TextBlock Text="{Binding Player.PlayPauseLabel}" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding Player.StopCommand}" Classes="icon" Padding="6,3"
                        ToolTip.Tip="{Binding Localization.TransportStopTip}" MinWidth="28">
                    <Path Data="{StaticResource IconSquare}" Width="9" Height="9" Stretch="Uniform"
                          Fill="{DynamicResource RythmboxTextBrush}" />
                </Button>
                <ToggleButton IsChecked="{Binding Player.IsLooping}" Classes="transportLoop" Padding="6,3"
                              ToolTip.Tip="{Binding Localization.TransportLoopTip}">
                    <StackPanel Orientation="Horizontal" Spacing="3">
                        <Path Data="{StaticResource IconRepeat}" Classes="icon small" />
                        <TextBlock Text="{Binding Localization.TransportLoop}" FontSize="10" FontWeight="Medium" />
                    </StackPanel>
                </ToggleButton>
                <Border Classes="headerDivider" Margin="4,0" />
                <Button Command="{Binding Tempo.TogglePickerCommand}" Classes="tempoDisplay"
                        ToolTip.Tip="{Binding Localization.HeaderTempo}">
                    <StackPanel Orientation="Horizontal" Spacing="3">
                        <TextBlock Text="{Binding Localization.HeaderTempo}" Classes="dim" FontSize="10" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Tempo.TempoLabel}" Classes="mono" FontSize="12" FontWeight="Medium" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding Tempo.TapTempoCommand}" Classes="compact" Padding="8,3"
                        ToolTip.Tip="{Binding Localization.HeaderTapTempo}"
                        Classes.tapActive="{Binding Tempo.IsAwaitingTap}">
                    <TextBlock Text="{Binding Localization.HeaderTapTempo}" FontSize="10" FontWeight="Medium"
                               MaxWidth="64" TextTrimming="CharacterEllipsis" />
                </Button>
                <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                    <Rectangle Classes="beatLed" Opacity="{Binding BeatLeds.Led0}" />
                    <Rectangle Classes="beatLed" Opacity="{Binding BeatLeds.Led1}" />
                    <Rectangle Classes="beatLed" Opacity="{Binding BeatLeds.Led2}" />
                    <Rectangle Classes="beatLed" Opacity="{Binding BeatLeds.Led3}" />
                </StackPanel>
                <TextBlock Text="{Binding ClockText}" Classes="mono dim" FontSize="10" VerticalAlignment="Center" Margin="6,0,0,0" />
            </StackPanel>

            <!-- Right: kit + audio chip + overflow -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="12,0,0,0">
                <Button Command="{Binding KitBrowser.BrowseLoadKitCommand}"
                        Classes="headerKit" MaxWidth="160" MinWidth="84"
                        ToolTip.Tip="{Binding Machine.KitLabel}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="{Binding Localization.HeaderKit}" Classes="dim" FontSize="10" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Machine.KitLabel}" FontSize="11" FontWeight="Medium"
                                   TextTrimming="CharacterEllipsis" MaxWidth="100" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Border Classes="audioStatusChip"
                        ToolTip.Tip="{Binding Machine.DeviceLabel}">
                    <TextBlock Text="{Binding Machine.AudioStatusChip}" FontSize="10" FontWeight="Medium"
                               MaxWidth="72" TextTrimming="CharacterEllipsis" />
                </Border>

                <Button Classes="icon" Padding="6,3" MinWidth="28"
                        ToolTip.Tip="{Binding Localization.HeaderMore}">
                    <Button.Flyout>
                        <MenuFlyout Placement="BottomEdgeAlignedRight">
                            <MenuItem Header="{Binding Localization.HeaderScan}"
                                      Command="{Binding Machine.StyleBank.RescanCommand}" />
                            <MenuItem Header="{Binding Localization.HeaderRescanKits}"
                                      Command="{Binding KitBrowser.RescanCommand}" />
                            <MenuItem Header="{Binding Localization.NavSubOutput}"
                                      Command="{Binding SubLoops.ToggleCommand}" />
                            <MenuItem Header="{Binding Localization.HeaderFullscreen}"
                                      Click="OnToggleFullscreenMenuClick" />
                            <Separator />
                            <MenuItem Header="{Binding Localization.HomeOpenAudio}"
                                      Command="{Binding NavigateCommand}"
                                      CommandParameter="{x:Static vm:AppPage.Settings}" />
                            <MenuItem Header="{Binding Localization.HeaderOpenStylesFolder}"
                                      Command="{Binding OpenStylesFolderCommand}" />
                            <MenuItem Header="{Binding Localization.HeaderOpenKitsFolder}"
                                      Command="{Binding OpenKitsFolderCommand}" />
                            <MenuItem Header="{Binding Localization.HeaderOpenSamplesFolder}"
                                      Command="{Binding OpenSamplesFolderCommand}" />
                            <Separator />
                            <MenuItem Header="{Binding Localization.NavSettings}"
                                      Command="{Binding NavigateCommand}"
                                      CommandParameter="{x:Static vm:AppPage.Settings}" />
                            <MenuItem Header="{Binding Localization.TransportQuit}"
                                      Command="{Binding QuitCommand}" />
                            <Separator />
                            <MenuItem Header="Shutdown" Command="{Binding ShutdownComputerCommand}" />
                            <MenuItem Header="Restart" Command="{Binding RestartComputerCommand}" />
                        </MenuFlyout>
                    </Button.Flyout>
                    <Path Data="{StaticResource IconMoreHorizontal}" Classes="icon small" />
                </Button>
            </StackPanel>

        </Grid>
    </Border>
</UserControl>
