<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Rythmbox.App.ViewModels"
             xmlns:engine="using:Rythmbox.Core.Engine"
             mc:Ignorable="d" d:DesignWidth="280" d:DesignHeight="400"
             x:Class="Rythmbox.App.Views.KitBrowserView"
             x:DataType="vm:KitBrowserViewModel">
    <Border Classes="panel">
        <DockPanel LastChildFill="True">
            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="DRUM KIT" Classes="panelHeader" />
                    <TextBlock Text="{Binding LoadedKitName, FallbackValue='No kit loaded'}" Classes="dim" TextTrimming="CharacterEllipsis" FontSize="11" />
                </StackPanel>
                <Button Grid.Column="1" Command="{Binding RescanCommand}" ToolTip.Tip="Rescan presets" Padding="6">
                    <Path Data="{StaticResource IconRefreshCw}" Classes="icon small" />
                </Button>
            </Grid>

            <ItemsControl DockPanel.Dock="Top" ItemsSource="{Binding HotloadSlots}" Margin="0,0,0,6">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:KitHotloadSlotViewModel">
                        <StackPanel Margin="2" Spacing="2">
                            <Button Command="{Binding LoadCommand}" ToolTip.Tip="{Binding ToolTip}" HorizontalAlignment="Stretch" Padding="6,4">
                                <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" FontSize="10" HorizontalAlignment="Center" />
                            </Button>
                            <Button Command="{Binding AssignCommand}" HorizontalAlignment="Stretch" Padding="4,1" ToolTip.Tip="Assign selected kit">
                                <TextBlock Text="Set" FontSize="9" HorizontalAlignment="Center" Classes="dim" />
                            </Button>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ListBox ItemsSource="{Binding Kits}" SelectedItem="{Binding SelectedKit}">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="engine:KitPresetEntry">
                        <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Border>
</UserControl>
