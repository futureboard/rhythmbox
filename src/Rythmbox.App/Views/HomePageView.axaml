<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Rythmbox.App.ViewModels"
             xmlns:views="using:Rythmbox.App.Views"
             mc:Ignorable="d" d:DesignWidth="1150" d:DesignHeight="720"
             x:Class="Rythmbox.App.Views.HomePageView"
             x:DataType="vm:MainWindowViewModel">
    <Grid ColumnDefinitions="*,320" Margin="32,28" ColumnSpacing="24">
        <StackPanel Grid.Column="0" Spacing="24" VerticalAlignment="Center" MaxWidth="640">
            <StackPanel Spacing="10">
                <views:LogoView Height="48" HorizontalAlignment="Left" />
                <TextBlock Text="{Binding Localization.HomeSubtitle}" Classes="dim" TextWrapping="Wrap"
                           FontSize="13" MaxWidth="520" />
            </StackPanel>

            <!-- Primary quick actions -->
            <StackPanel Spacing="8">
                <TextBlock Text="QUICK ACTIONS" Classes="panelHeader" FontSize="11" />
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto"
                      ColumnSpacing="8" RowSpacing="8">
                    <Button Grid.Row="0" Grid.Column="0"
                            Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:AppPage.Machine}"
                            Classes="accent" HorizontalAlignment="Stretch" MinHeight="40">
                        <TextBlock Text="{Binding Localization.HomeStartPlaying}" FontWeight="Bold"
                                   Foreground="{DynamicResource RythmboxOnAccentBrush}" HorizontalAlignment="Center" />
                    </Button>
                    <Button Grid.Row="0" Grid.Column="1"
                            Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:AppPage.Machine}"
                            Classes="homeTile" HorizontalAlignment="Stretch" MinHeight="40" Padding="12,8">
                        <TextBlock Text="{Binding Localization.HomeLoadStyle}" FontWeight="SemiBold" FontSize="12" />
                    </Button>
                    <Button Grid.Row="1" Grid.Column="0"
                            Command="{Binding KitBrowser.BrowseLoadKitCommand}"
                            Classes="homeTile" HorizontalAlignment="Stretch" MinHeight="40" Padding="12,8">
                        <TextBlock Text="{Binding Localization.HomeLoadKit}" FontWeight="SemiBold" FontSize="12" />
                    </Button>
                    <Button Grid.Row="1" Grid.Column="1"
                            Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:AppPage.Settings}"
                            Classes="homeTile" HorizontalAlignment="Stretch" MinHeight="40" Padding="12,8">
                        <TextBlock Text="{Binding Localization.HomeOpenAudio}" FontWeight="SemiBold" FontSize="12" />
                    </Button>
                </Grid>
            </StackPanel>

            <!-- Mode tiles -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto"
                  ColumnSpacing="8" RowSpacing="8">
                <Button Grid.Row="0" Grid.Column="0"
                        Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:AppPage.Pads}"
                        Classes="homeTile" HorizontalAlignment="Stretch">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding Localization.NavPads}" FontWeight="Bold" FontSize="13" />
                        <TextBlock Text="{Binding Localization.HomePadsHint}" Classes="dim" FontSize="11" TextWrapping="Wrap" />
                    </StackPanel>
                </Button>
                <Button Grid.Row="0" Grid.Column="1"
                        Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:AppPage.Mixer}"
                        Classes="homeTile" HorizontalAlignment="Stretch">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding Localization.NavMixer}" FontWeight="Bold" FontSize="13" />
                        <TextBlock Text="{Binding Localization.HomeMixerHint}" Classes="dim" FontSize="11" TextWrapping="Wrap" />
                    </StackPanel>
                </Button>
                <Button Grid.Row="1" Grid.Column="0"
                        Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:AppPage.Editor}"
                        Classes="homeTile" HorizontalAlignment="Stretch">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding Localization.NavEditor}" FontWeight="Bold" FontSize="13" />
                        <TextBlock Text="{Binding Localization.HomeEditorHint}" Classes="dim" FontSize="11" TextWrapping="Wrap" />
                    </StackPanel>
                </Button>
                <Button Grid.Row="1" Grid.Column="1"
                        Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:AppPage.Macro}"
                        Classes="homeTile" HorizontalAlignment="Stretch">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding Localization.NavMacro}" FontWeight="Bold" FontSize="13" />
                        <TextBlock Text="{Binding Localization.HomeMacroHint}" Classes="dim" FontSize="11" TextWrapping="Wrap" />
                    </StackPanel>
                </Button>
                <Button Grid.Row="2" Grid.Column="0"
                        Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:AppPage.Files}"
                        Classes="homeTile" HorizontalAlignment="Stretch">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding Localization.NavFiles}" FontWeight="Bold" FontSize="13" />
                        <TextBlock Text="Browse styles, kits, and samples" Classes="dim" FontSize="11" TextWrapping="Wrap" />
                    </StackPanel>
                </Button>
                <Button Grid.Row="2" Grid.Column="1"
                        Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:AppPage.Settings}"
                        Classes="homeTile" HorizontalAlignment="Stretch">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding Localization.NavSettings}" FontWeight="Bold" FontSize="13" />
                        <TextBlock Text="{Binding Localization.HomeSettingsHint}" Classes="dim" FontSize="11" TextWrapping="Wrap" />
                    </StackPanel>
                </Button>
            </Grid>
        </StackPanel>

        <Border Grid.Column="1" Classes="panel" Padding="16" VerticalAlignment="Center">
            <StackPanel Spacing="14">
                <TextBlock Text="{Binding Localization.HomeStatusTitle}" Classes="panelHeader" />
                <StackPanel Spacing="10">
                    <StackPanel Spacing="2">
                        <TextBlock Text="{Binding Localization.HomeKitLabel}" Classes="dim" FontSize="10" />
                        <TextBlock Text="{Binding Machine.KitLabel}" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Spacing="2">
                        <TextBlock Text="{Binding Localization.HomeStyleLabel}" Classes="dim" FontSize="10" />
                        <TextBlock Text="{Binding Machine.StyleLabel}" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Spacing="2">
                        <TextBlock Text="{Binding Localization.HomePatternLabel}" Classes="dim" FontSize="10" />
                        <TextBlock Text="{Binding Machine.PatternLabel}" FontSize="12" FontWeight="SemiBold" />
                    </StackPanel>
                    <StackPanel Spacing="2">
                        <TextBlock Text="{Binding Localization.HomeDeviceLabel}" Classes="dim" FontSize="10" />
                        <TextBlock Text="{Binding Machine.DeviceLabel}" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Spacing="2">
                        <TextBlock Text="{Binding Localization.HomeTransportLabel}" Classes="dim" FontSize="10" />
                        <TextBlock Text="{Binding Machine.TransportLabel}" FontSize="12" FontWeight="SemiBold" />
                    </StackPanel>
                </StackPanel>
                <Button Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:AppPage.Machine}"
                        Classes="accent" HorizontalAlignment="Stretch" Margin="0,4,0,0" MinHeight="36">
                    <TextBlock Text="{Binding Localization.HomeStartPlaying}" FontWeight="Bold"
                               Foreground="{DynamicResource RythmboxOnAccentBrush}" HorizontalAlignment="Center" />
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
