<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Rythmbox.App.ViewModels"
             mc:Ignorable="d" d:DesignWidth="272" d:DesignHeight="120"
             x:Class="Rythmbox.App.Views.TransportView"
             x:DataType="vm:MainWindowViewModel">
    <!-- Machine-page local transport: play/stop/loop + time signature only.
         Global scan / tap / power live in the header. -->
    <Border Classes="region regionRight">
        <StackPanel Spacing="6">
            <TextBlock Text="{Binding Localization.TransportTitle}" Classes="panelHeader" />

            <Grid ColumnDefinitions="*,Auto">
                <Button Grid.Column="0" Command="{Binding Player.PlayPauseCommand}"
                        HorizontalAlignment="Stretch" Height="40" Classes="transportPlay"
                        Classes.playing="{Binding Player.IsPlaying}" Margin="0,0,1,0"
                        ToolTip.Tip="{Binding Localization.TransportPlayTip}">
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <Path Data="{StaticResource IconSquare}" Width="14" Height="14" Stretch="Uniform"
                              Fill="{Binding $parent[Button].Foreground}"
                              IsVisible="{Binding Player.IsPlaying}" />
                        <Path Data="{StaticResource IconPlay}" Width="14" Height="14" Stretch="Uniform"
                              Fill="{Binding $parent[Button].Foreground}"
                              IsVisible="{Binding !Player.IsPlaying}" />
                        <TextBlock Text="{Binding Player.PlayPauseLabel}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="1" Command="{Binding Player.StopCommand}" Height="40" Width="40"
                        ToolTip.Tip="{Binding Localization.TransportStopTip}">
                    <Path Data="{StaticResource IconSquare}" Width="12" Height="12" Stretch="Uniform"
                          Fill="{DynamicResource RythmboxTextBrush}" />
                </Button>
            </Grid>

            <Grid ColumnDefinitions="*,*">
                <ToggleButton Grid.Column="0" IsChecked="{Binding Player.IsLooping}"
                              Classes="transportLoop" Margin="0,0,1,0" HorizontalAlignment="Stretch"
                              ToolTip.Tip="{Binding Localization.TransportLoopTip}">
                    <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                        <Path Data="{StaticResource IconRepeat}" Classes="icon small" />
                        <TextBlock Text="{Binding Localization.TransportLoop}" FontSize="11" />
                    </StackPanel>
                </ToggleButton>
                <Button Grid.Column="1" Command="{Binding NavigateCommand}"
                        CommandParameter="{x:Static vm:AppPage.Mixer}" HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                        <Path Data="{StaticResource IconSlidersHorizontal}" Classes="icon small" />
                        <TextBlock Text="{Binding Localization.TransportMixer}" FontSize="11" />
                    </StackPanel>
                </Button>
            </Grid>

            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding Localization.TransportTimeSig}" Classes="dim" FontSize="10" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{Binding Machine.TimeSignatureLabel}" Classes="mono" FontSize="11"
                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="6,0,0,0" />
                <Button Grid.Column="2" Command="{Binding Machine.SwitchTimeSignatureCommand}" Padding="8,2" Margin="4,0,0,0"
                        ToolTip.Tip="Drop a momentary bar (also mapped to a MIDI CC foot switch)"
                        Classes.tapActive="{Binding Machine.TimeSignatureSwitchPending}">
                    <TextBlock Text="2/4" FontSize="10" FontWeight="SemiBold" />
                </Button>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
