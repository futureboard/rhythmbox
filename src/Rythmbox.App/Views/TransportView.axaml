<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Rythmbox.App.ViewModels"
             mc:Ignorable="d" d:DesignWidth="272" d:DesignHeight="200"
             x:Class="Rythmbox.App.Views.TransportView"
             x:DataType="vm:MainWindowViewModel">
    <Border Classes="region regionRight">
        <StackPanel Spacing="4">
            <TextBlock Text="{Binding Localization.TransportTitle}" Classes="panelHeader" />

            <Grid ColumnDefinitions="*,Auto">
                <Button Grid.Column="0" Command="{Binding Player.PlayPauseCommand}" HorizontalAlignment="Stretch" Height="40" Classes="transportStop" Margin="0,0,1,0">
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <Path Data="{StaticResource IconSquare}" Width="14" Height="14" Stretch="Uniform"
                              Fill="White" Stroke="White" StrokeThickness="0" IsVisible="{Binding Player.IsPlaying}" />
                        <Path Data="{StaticResource IconPlay}" Width="14" Height="14" Stretch="Uniform"
                              Fill="White" Stroke="White" StrokeThickness="0" IsVisible="{Binding !Player.IsPlaying}" />
                        <TextBlock Text="{Binding Player.PlayPauseLabel}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="1" Command="{Binding Player.StopCommand}" Height="40" Width="40" ToolTip.Tip="Stop and rewind">
                    <Path Data="{StaticResource IconSquare}" Width="12" Height="12" Stretch="Uniform" Fill="White" Stroke="White" StrokeThickness="0" />
                </Button>
            </Grid>

            <Grid ColumnDefinitions="*,*">
                <ToggleButton Grid.Column="0" IsChecked="{Binding Player.IsLooping}" Margin="0,0,1,0" HorizontalAlignment="Stretch" ToolTip.Tip="Loop the current file">
                    <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                        <Path Data="{StaticResource IconRepeat}" Classes="icon small" />
                        <TextBlock Text="{Binding Localization.TransportLoop}" FontSize="11" />
                    </StackPanel>
                </ToggleButton>
                <Button Grid.Column="1" Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:AppPage.Mixer}" HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                        <Path Data="{StaticResource IconSlidersHorizontal}" Classes="icon small" />
                        <TextBlock Text="{Binding Localization.TransportMixer}" FontSize="11" />
                    </StackPanel>
                </Button>
            </Grid>

            <Grid ColumnDefinitions="*,*">
                <Button Grid.Column="0" Command="{Binding Machine.StyleBank.RescanCommand}" Margin="0,0,1,0" HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                        <Path Data="{StaticResource IconRefreshCw}" Classes="icon small" />
                        <TextBlock Text="{Binding Localization.TransportScan}" FontSize="11" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="1" Command="{Binding QuitCommand}" HorizontalAlignment="Stretch" Classes="danger">
                    <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                        <Path Data="{StaticResource IconPower}" Classes="icon small danger" />
                        <TextBlock Text="{Binding Localization.TransportQuit}" FontSize="11" />
                    </StackPanel>
                </Button>
            </Grid>

            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding Tempo.TempoLabel, StringFormat='{}{0:0.0} BPM'}" Classes="mono" FontSize="11" VerticalAlignment="Center" />
                <Button Grid.Column="1" Command="{Binding Tempo.TapTempoCommand}" Padding="8,2" Margin="4,0,0,0"
                        ToolTip.Tip="Tap tempo (T)" Classes.tapActive="{Binding Tempo.IsAwaitingTap}">
                    <TextBlock Text="{Binding Localization.TransportTapTempo}" FontSize="10" FontWeight="SemiBold" />
                </Button>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
