<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Rythmbox.App.ViewModels"
             mc:Ignorable="d" d:DesignWidth="320" d:DesignHeight="220"
             x:Class="Rythmbox.App.Views.TransportView"
             x:DataType="vm:MainWindowViewModel">
    <Border Classes="panel">
        <StackPanel Spacing="8">
            <TextBlock Text="TRANSPORT" Classes="panelHeader" />

            <Button Command="{Binding Player.PlayPauseCommand}" HorizontalAlignment="Stretch" Height="52" Classes="transportStop">
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                    <Path Data="{StaticResource IconSquare}" Width="16" Height="16" Stretch="Uniform"
                          Fill="White" Stroke="White" StrokeThickness="0" IsVisible="{Binding Player.IsPlaying}" />
                    <Path Data="{StaticResource IconPlay}" Width="16" Height="16" Stretch="Uniform"
                          Fill="White" Stroke="White" StrokeThickness="0" IsVisible="{Binding !Player.IsPlaying}" />
                    <TextBlock Text="{Binding Player.PlayPauseLabel}" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <Grid ColumnDefinitions="*,*">
                <ToggleButton Grid.Column="0" IsChecked="{Binding Player.IsLooping}" Margin="0,0,4,0" HorizontalAlignment="Stretch"
                              ToolTip.Tip="Loop the current file (SUB)">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                        <Path Data="{StaticResource IconRepeat}" Classes="icon small" />
                        <TextBlock Text="SUB" />
                    </StackPanel>
                </ToggleButton>
                <ToggleButton Grid.Column="1" IsChecked="{Binding IsMixerOpen}" Margin="4,0,0,0" HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                        <Path Data="{StaticResource IconSlidersHorizontal}" Classes="icon small" />
                        <TextBlock Text="MIXER" />
                    </StackPanel>
                </ToggleButton>
            </Grid>

            <Grid ColumnDefinitions="*,*">
                <Button Grid.Column="0" Command="{Binding LoopBrowser.RescanCommand}" Margin="0,0,4,0" HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                        <Path Data="{StaticResource IconRefreshCw}" Classes="icon small" />
                        <TextBlock Text="RESCAN" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="1" Command="{Binding QuitCommand}" Margin="4,0,0,0" HorizontalAlignment="Stretch" Classes="danger">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                        <Path Data="{StaticResource IconPower}" Classes="icon small danger" />
                        <TextBlock Text="QUIT" />
                    </StackPanel>
                </Button>
            </Grid>

            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding Player.Bpm, StringFormat='{}{0:0.0} BPM'}" Classes="mono" VerticalAlignment="Center" />
                <Button Grid.Column="1" Command="{Binding SoundFontBrowser.ToggleMidiConnectionCommand}"
                        ToolTip.Tip="Connect a physical MIDI keyboard to play the loaded SoundFont live">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                        <Path Data="{StaticResource IconPlug}" Classes="icon small" />
                        <TextBlock Text="{Binding SoundFontBrowser.ConnectLabel}" />
                    </StackPanel>
                </Button>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
