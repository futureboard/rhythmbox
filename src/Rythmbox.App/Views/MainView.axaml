<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Rythmbox.App.ViewModels"
             xmlns:views="using:Rythmbox.App.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1150" d:DesignHeight="720"
             x:Class="Rythmbox.App.Views.MainView"
             x:DataType="vm:MainWindowViewModel"
             Background="{DynamicResource RythmboxBackgroundBrush}"
             Focusable="True"
             KeyDown="OnWindowKeyDown"
             KeyUp="OnWindowKeyUp">

    <Grid>
    <!-- In-app (application) scaling: an app-controlled zoom independent of the
         operating-system / monitor DPI. Driven by MainWindowViewModel.AppScale. -->
    <LayoutTransformControl x:Name="AppScaleHost">
        <LayoutTransformControl.LayoutTransform>
            <ScaleTransform ScaleX="{Binding AppScale, FallbackValue=1.0}"
                            ScaleY="{Binding AppScale, FallbackValue=1.0}" />
        </LayoutTransformControl.LayoutTransform>
        <DockPanel x:Name="AppShell" IsVisible="False" LastChildFill="True">
            <views:HeaderView DockPanel.Dock="Top" />
            <views:NavBarView DockPanel.Dock="Top" />
            <views:FooterView DockPanel.Dock="Bottom" />

            <Panel>
                <views:HomePageView IsVisible="{Binding IsHomePage}" />
                <views:MachinePageView IsVisible="{Binding IsMachinePage}" />
                <views:PadsPageView IsVisible="{Binding IsPadsPage}" />

                <views:MixerPageView IsVisible="{Binding IsMixerPage}" />
                <views:SettingsView IsVisible="{Binding IsSettingsPage}" />
                <views:EditorPageHostView IsVisible="{Binding IsEditorPage}" />
                <views:SampleCreatorPageHostView IsVisible="{Binding IsMacroPage}" />
                <views:FileManagerPageView IsVisible="{Binding IsFilesPage}" />
                <views:PlaceholderPageView IsVisible="{Binding IsChromePage}" Title="CHROME" />

                <views:FileManagerDialogView DataContext="{Binding FileDialog}" />

                <Border Classes="popupOverlay" IsVisible="{Binding Tempo.IsPickerOpen}" ZIndex="100">
                    <Border Classes="popupPanel" MaxWidth="320" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel Spacing="8">
                            <TextBlock Text="TEMPO PRESETS" Classes="panelHeader" />
                            <ListBox ItemsSource="{Binding Tempo.Presets}"
                                     SelectedItem="{Binding Tempo.SelectedPresetInPicker}" MaxHeight="240" />
                            <Button Content="Close" Command="{Binding Tempo.TogglePickerCommand}" HorizontalAlignment="Right" />
                        </StackPanel>
                    </Border>
                </Border>

                <Border Classes="popupOverlay" IsVisible="{Binding SubLoops.IsOpen}" ZIndex="100">
                    <Border Classes="popupPanel" MaxWidth="480" MaxHeight="400" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <DockPanel LastChildFill="True">
                            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                                <TextBlock Text="SUB LOOPS" Classes="panelHeader" />
                                <Button Grid.Column="1" Command="{Binding SubLoops.CloseCommand}" Content="Close" />
                            </Grid>
                            <ListBox ItemsSource="{Binding SubLoops.SubLoops}" SelectedItem="{Binding SubLoops.SelectedSubLoop}" Classes="loopList" />
                        </DockPanel>
                    </Border>
                </Border>

                <Border Classes="popupOverlay" IsVisible="{Binding KitBrowser.IsLoading}" ZIndex="500">
                    <Border Classes="popupPanel" Width="360" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel Spacing="12">
                            <TextBlock Text="LOADING KIT" Classes="panelHeader" />
                            <TextBlock Text="{Binding KitBrowser.LoadingMessage}" TextWrapping="Wrap" />
                            <ProgressBar Minimum="0" Maximum="1" Value="{Binding KitBrowser.LoadingProgress}" />
                            <TextBlock Text="Sample attacks are pre-warmed; longer audio stays mapped until played." Classes="dim" FontSize="10" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Border>
            </Panel>
        </DockPanel>
    </LayoutTransformControl>

    <!-- The runtime initializes behind this in the same native surface. -->
    <Border x:Name="SplashOverlay" Classes="splashSurface" ZIndex="1000">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="320" Spacing="14">
            <views:LogoView Height="34" HorizontalAlignment="Center" />
            <StackPanel Spacing="3" HorizontalAlignment="Center">
                <TextBlock Text="RHYTHM WORKSTATION" Classes="panelHeader" FontSize="12" HorizontalAlignment="Center" />
                <TextBlock Text="Preparing your performance environment" Classes="dim" FontSize="11" HorizontalAlignment="Center" />
            </StackPanel>
            <Border Classes="splashProgressFrame">
                <ProgressBar Classes="splashProgress" IsIndeterminate="True" />
            </Border>
            <TextBlock x:Name="SplashStatus" Text="Loading runtime…" Classes="splashStatus"
                       HorizontalAlignment="Center" TextAlignment="Center" />
        </StackPanel>
    </Border>

    <!-- Software mouse cursor for the embedded DRM/KMS host (inert on desktop). -->
    <views:SoftwareCursorLayer ZIndex="2000" />
    </Grid>
</UserControl>
