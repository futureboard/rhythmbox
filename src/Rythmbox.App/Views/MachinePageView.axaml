<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="using:Rythmbox.App.Views"
             mc:Ignorable="d" d:DesignWidth="1150" d:DesignHeight="720"
             x:Class="Rythmbox.App.Views.MachinePageView">
    <Grid RowDefinitions="*,220" ColumnDefinitions="272,*">
        <Grid Grid.Row="0" Grid.Column="0" RowDefinitions="*,Auto">
            <views:ArrangerLeftPanelView Grid.Row="0" />
            <views:TransportView Grid.Row="1" />
        </Grid>
        <views:PercussionPadGridView Grid.Row="0" Grid.Column="1" />
        <views:StyleBankView Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" />
    </Grid>
</UserControl>
