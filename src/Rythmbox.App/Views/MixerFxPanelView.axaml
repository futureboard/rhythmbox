<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Rythmbox.App.ViewModels"
             mc:Ignorable="d" d:DesignWidth="680" d:DesignHeight="380"
             x:Class="Rythmbox.App.Views.MixerFxPanelView"
             x:DataType="vm:ChannelDspViewModel">
    <Border Classes="mixerFxPanel" Padding="14">
        <Grid ColumnDefinitions="124,*" ColumnSpacing="14">
            <!-- Inserts are deliberately vertical, like a console channel's effects rack. -->
            <StackPanel Grid.Column="0" Spacing="6">
                <TextBlock Text="INSERT SLOTS" Classes="mixerFxSection" />
                <ToggleButton Content="EQ" IsChecked="{Binding EqEnabled}" Classes="mixerFxPopupSlot" />
                <ToggleButton Content="COMPRESSOR" IsChecked="{Binding CompressorEnabled}" Classes="mixerFxPopupSlot" />
                <ToggleButton Content="DELAY" IsChecked="{Binding DelayEnabled}" Classes="mixerFxPopupSlot" />
                <ToggleButton Content="REVERB" IsChecked="{Binding ReverbEnabled}" Classes="mixerFxPopupSlot" />
            </StackPanel>

            <StackPanel Grid.Column="1" Spacing="14">
                <StackPanel Spacing="7">
                    <TextBlock Text="INPUT &amp; EQ" Classes="mixerFxSection" />
                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="10" IsEnabled="{Binding EqEnabled}">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Trim" Classes="dim" FontSize="10" />
                            <Slider Minimum="-24" Maximum="12" Value="{Binding TrimGainDb}" TickFrequency="3" />
                            <TextBlock Text="{Binding TrimGainDb, StringFormat={}{0:0.0} dB}" FontSize="10" HorizontalAlignment="Center" Classes="mono" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="Low" Classes="dim" FontSize="10" />
                            <Slider Minimum="-12" Maximum="12" Value="{Binding LowGainDb}" />
                            <TextBlock Text="{Binding LowGainDb, StringFormat={}{0:0.0} dB}" FontSize="10" HorizontalAlignment="Center" Classes="mono" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Text="Mid" Classes="dim" FontSize="10" />
                            <Slider Minimum="-12" Maximum="12" Value="{Binding MidGainDb}" />
                            <TextBlock Text="{Binding MidGainDb, StringFormat={}{0:0.0} dB}" FontSize="10" HorizontalAlignment="Center" Classes="mono" />
                        </StackPanel>
                        <StackPanel Grid.Column="3" Spacing="4">
                            <TextBlock Text="High" Classes="dim" FontSize="10" />
                            <Slider Minimum="-12" Maximum="12" Value="{Binding HighGainDb}" />
                            <TextBlock Text="{Binding HighGainDb, StringFormat={}{0:0.0} dB}" FontSize="10" HorizontalAlignment="Center" Classes="mono" />
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <StackPanel Spacing="7">
                    <TextBlock Text="DYNAMICS &amp; TIME" Classes="mixerFxSection" />
                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="10">
                        <StackPanel Grid.Column="0" Spacing="4" IsEnabled="{Binding CompressorEnabled}">
                            <TextBlock Text="Comp threshold" Classes="dim" FontSize="10" />
                            <Slider Minimum="-48" Maximum="0" Value="{Binding CompressorThresholdDb}" />
                            <TextBlock Text="{Binding CompressorThresholdDb, StringFormat=Thr {0:0} dB}" FontSize="10" HorizontalAlignment="Center" Classes="mono" />
                            <Slider Minimum="1" Maximum="12" Value="{Binding CompressorRatio}" />
                            <TextBlock Text="{Binding CompressorRatio, StringFormat={}{0:0.0}:1}" FontSize="10" HorizontalAlignment="Center" Classes="mono" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4" IsEnabled="{Binding DelayEnabled}">
                            <TextBlock Text="Delay time" Classes="dim" FontSize="10" />
                            <Slider Minimum="0" Maximum="750" Value="{Binding DelayTimeMs}" />
                            <TextBlock Text="{Binding DelayTimeMs, StringFormat={}{0:0} ms}" FontSize="10" HorizontalAlignment="Center" Classes="mono" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4" IsEnabled="{Binding DelayEnabled}">
                            <TextBlock Text="Delay feedback" Classes="dim" FontSize="10" />
                            <Slider Minimum="0" Maximum="90" Value="{Binding DelayFeedback}" />
                            <TextBlock Text="{Binding DelayFeedback, StringFormat={}{0:0}%}" FontSize="10" HorizontalAlignment="Center" Classes="mono" />
                            <TextBlock Text="Delay mix" Classes="dim" FontSize="10" />
                            <Slider Minimum="0" Maximum="100" Value="{Binding DelayMix}" />
                        </StackPanel>
                        <StackPanel Grid.Column="3" Spacing="4" IsEnabled="{Binding ReverbEnabled}">
                            <TextBlock Text="Reverb mix" Classes="dim" FontSize="10" />
                            <Slider Minimum="0" Maximum="100" Value="{Binding ReverbMix}" />
                            <TextBlock Text="{Binding ReverbMix, StringFormat=Mix {0:0}%}" FontSize="10" HorizontalAlignment="Center" Classes="mono" />
                            <TextBlock Text="Reverb size" Classes="dim" FontSize="10" />
                            <Slider Minimum="0" Maximum="100" Value="{Binding ReverbSize}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
