<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Rythmbox.App.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1150" d:DesignHeight="200"
             x:Class="Rythmbox.App.Views.LoopBrowserView"
             x:DataType="vm:MainWindowViewModel">
    <Border Classes="region regionRight">
        <DockPanel LastChildFill="True">
            <Border DockPanel.Dock="Top" BorderBrush="{DynamicResource RythmboxPanelBorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,6" Margin="0,0,0,6">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                        <TextBlock Classes="panelHeader">
                            <Run Text="MIDI LOOP BROWSER" />
                            <Run Text=" — " />
                            <Run Text="{Binding LoopBrowser.FolderLabel}" />
                        </TextBlock>
                        <TextBlock Classes="dim">
                            <Run Text="(" /><Run Text="{Binding LoopBrowser.TotalCount}" /><Run Text=" loops)" />
                        </TextBlock>
                    </StackPanel>
                    <Button Grid.Column="1" Click="OnBrowseFolderClick" Padding="8,4">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <Path Data="{StaticResource IconFolderOpen}" Classes="icon small" />
                            <TextBlock Text="Browse Folder…" FontSize="11" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <Grid ColumnDefinitions="140,*">
                <Border Grid.Column="0" Classes="bankList">
                    <ListBox ItemsSource="{Binding LoopBrowser.Banks}" SelectedItem="{Binding LoopBrowser.SelectedBank}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:LoopBankViewModel">
                                <TextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <ListBox Grid.Column="1" ItemsSource="{Binding LoopBrowser.Loops}" SelectedItem="{Binding LoopBrowser.SelectedLoop}" Classes="loopList">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:LoopEntryViewModel">
                            <Grid ColumnDefinitions="20,*,80,80,90">
                                <Path Grid.Column="0" Data="{StaticResource IconPlay}" Width="10" Height="10" Stretch="Uniform"
                                      Fill="White" Stroke="White" StrokeThickness="0" IsVisible="{Binding IsSelected}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="{Binding HitsLabel}" Classes="dim" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="3" Text="{Binding DurationLabel}" Classes="dim" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="4" Text="{Binding BpmLabel}" Classes="dim" HorizontalAlignment="Right" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </DockPanel>
    </Border>
</UserControl>
