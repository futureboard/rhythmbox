<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Rythmbox.App.ViewModels"
             xmlns:views="using:Rythmbox.App.Views"
             mc:Ignorable="d" d:DesignWidth="1150" d:DesignHeight="650"
             x:Class="Rythmbox.App.Views.MixerPageView"
             x:DataType="vm:MainWindowViewModel">
    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0" Classes="mixerPageHeader" Padding="14,9">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Path Data="{StaticResource IconSlidersHorizontal}" Classes="icon small" />
                    <StackPanel Spacing="0" VerticalAlignment="Center">
                        <TextBlock Text="MIX" Classes="dim" FontSize="8" FontWeight="Bold" LetterSpacing="1" />
                        <TextBlock Text="{Binding Localization.MixerTitle}" Classes="panelHeader" VerticalAlignment="Center" />
                    </StackPanel>
                    <Border Classes="mixerCountBadge">
                        <TextBlock Text="{Binding Mixer.ChannelCountLabel}" FontSize="9" Classes="dim" />
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16" Margin="16,0,0,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="{Binding Localization.HeaderBackend}" Classes="dim" FontSize="10" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Mixer.BackendLabel}" FontSize="11" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4" MaxWidth="320">
                        <TextBlock Text="{Binding Localization.HeaderDevice}" Classes="dim" FontSize="10" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Mixer.DeviceLabel}" FontSize="11" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <Button Command="{Binding NavigateCommand}"
                            CommandParameter="{x:Static vm:AppPage.Settings}"
                            Padding="8,4"
                            ToolTip.Tip="{Binding Localization.HomeOpenAudio}">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <Path Data="{StaticResource IconPlug}" Classes="icon small" />
                            <TextBlock Text="{Binding Localization.HomeOpenAudio}" FontSize="11" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding SubLoops.ToggleCommand}" Padding="8,4"
                            ToolTip.Tip="{Binding Localization.HeaderSubOutputTip}">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <Path Data="{StaticResource IconRepeat}" Classes="icon small" />
                            <TextBlock Text="{Binding Localization.NavSubOutput}" FontSize="11" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Button Grid.Column="2" Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:AppPage.Machine}"
                        Padding="8,4" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Path Data="{StaticResource IconChevronLeft}" Classes="icon small" />
                        <TextBlock Text="{Binding Localization.MixerMachine}" FontSize="11" FontWeight="Medium" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <views:MixerSurfaceView DataContext="{Binding Mixer}" />

            <!-- Keep the full mixer surface available; FX opens above it like a DAW editor. -->
            <Border IsVisible="{Binding Mixer.IsFxEditorOpen}"
                    Background="#99090C09"
                    ZIndex="10">
                <Border Classes="mixerFxPopup"
                        Width="700"
                        MaxHeight="560"
                        Margin="20"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top">
                    <Grid RowDefinitions="Auto,*">
                        <Border Grid.Row="0" Classes="mixerFxPopupHeader" Padding="14,10">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="FX EDITOR" Classes="mixerFxSection" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Mixer.SelectedChannel.Name}" Classes="panelHeader" FontSize="13" VerticalAlignment="Center" />
                                </StackPanel>
                                <Button Grid.Column="1" Command="{Binding Mixer.CloseFxEditorCommand}" Classes="mixerFxClose" ToolTip.Tip="Close FX editor">
                                    <Path Data="{StaticResource IconX}" Classes="icon small" />
                                </Button>
                            </Grid>
                        </Border>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <views:MixerFxPanelView DataContext="{Binding Mixer.SelectedChannelFx}" />
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Border>
        </Grid>
    </Grid>
</UserControl>
