<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Rythmbox.App.ViewModels"
             xmlns:views="using:Rythmbox.App.Views"
             mc:Ignorable="d" d:DesignWidth="1150" d:DesignHeight="650"
             x:Class="Rythmbox.App.Views.MixerPageView"
             x:DataType="vm:MainWindowViewModel">
    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top" Classes="region regionBottom" Padding="8,6">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="MIXER" Classes="panelHeader" VerticalAlignment="Center" />
                <Button Grid.Column="1" Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:AppPage.Machine}" Classes="accent" Padding="8,4">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Path Data="{StaticResource IconChevronLeft}" Classes="icon small" Stroke="#1A1A1A" />
                        <TextBlock Text="Machine" Foreground="#1A1A1A" FontWeight="Bold" FontSize="11" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <views:MasterStripView DockPanel.Dock="Top" DataContext="{Binding MasterStrip}" />

        <Border Classes="region regionFill" Padding="0">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal" Spacing="0">
                    <views:BusMixerView />
                    <Border Width="1" Background="{DynamicResource RythmboxPanelBorderBrush}" />
                    <views:PadMixerView />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </DockPanel>
</UserControl>
