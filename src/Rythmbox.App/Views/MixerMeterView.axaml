<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Rythmbox.App.ViewModels"
             xmlns:views="using:Rythmbox.App.Views"
             mc:Ignorable="d" d:DesignWidth="24" d:DesignHeight="120"
             x:Class="Rythmbox.App.Views.MixerMeterView"
             x:DataType="vm:MixerMeterViewModel">
    <views:MixerGpuMeterView RmsLeft="{Binding RmsLeft}"
                             RmsRight="{Binding RmsRight}"
                             PeakLeft="{Binding PeakLeft}"
                             PeakRight="{Binding PeakRight}"
                             IsClipping="{Binding IsClipping}"
                             HasSignalData="{Binding HasSignalData}"
                             Height="120"
                             Width="24" />
</UserControl>
