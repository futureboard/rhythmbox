<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Rythmbox.App.ViewModels"
             xmlns:structs="using:SoundFlow.Structs"
             mc:Ignorable="d" d:DesignWidth="1150" d:DesignHeight="500"
             x:Class="Rythmbox.App.Views.SettingsView"
             x:DataType="vm:MainWindowViewModel">
    <Border Classes="region regionFill">
        <ScrollViewer>
            <StackPanel Spacing="0">
                <Border BorderBrush="{DynamicResource RythmboxPanelBorderBrush}" BorderThickness="0,0,0,1" Padding="14,12" Margin="0,0,0,8">
                    <StackPanel Spacing="2">
                        <TextBlock Text="SYSTEM" Classes="dim" FontSize="9" FontWeight="Bold" LetterSpacing="1" />
                        <TextBlock Text="{Binding Localization.SettingsTitle}" Classes="panelHeader" FontSize="12" />
                        <TextBlock Text="{Binding Localization.SettingsSubtitle}" Classes="dim" />
                    </StackPanel>
                </Border>

                <Border Classes="settingsPanel">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{Binding Localization.SettingsLanguage}" FontWeight="Bold" />
                        <TextBlock Text="{Binding Localization.SettingsLanguageDesc}" Classes="dim" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ToggleButton Content="{Binding Localization.SettingsLangEnglish}"
                                          IsChecked="{Binding Localization.IsEnglish}"
                                          Command="{Binding Localization.SetEnglishCommand}"
                                          Padding="12,6" />
                            <ToggleButton Content="{Binding Localization.SettingsLangThai}"
                                          IsChecked="{Binding Localization.IsThai}"
                                          Command="{Binding Localization.SetThaiCommand}"
                                          Padding="12,6" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Classes="settingsPanel">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{Binding Localization.SettingsAppScale}" FontWeight="Bold" />
                        <TextBlock Text="{Binding Localization.SettingsAppScaleDesc}" Classes="dim" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Button Content="−" Width="36" Command="{Binding DecreaseAppScaleCommand}" />
                            <Border MinWidth="70" Padding="10,6" VerticalAlignment="Center"
                                    Background="{DynamicResource RythmboxPanelBorderBrush}" CornerRadius="4">
                                <TextBlock Text="{Binding AppScaleLabel}" Classes="mono" HorizontalAlignment="Center" />
                            </Border>
                            <Button Content="+" Width="36" Command="{Binding IncreaseAppScaleCommand}" />
                            <Button Content="{Binding Localization.SettingsAppScaleReset}" Command="{Binding ResetAppScaleCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Classes="settingsPanel">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{Binding Localization.SettingsAudioOutput}" FontWeight="Bold" />
                        <TextBlock Text="{Binding Settings.AudioDeviceLabel}" Classes="dim" TextWrapping="Wrap" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <ComboBox Grid.Column="0"
                                      ItemsSource="{Binding Settings.OutputDevices}"
                                      SelectedItem="{Binding Settings.SelectedOutputDevice}"
                                      PlaceholderText="{Binding Localization.MixerSelectOutput}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="structs:DeviceInfo">
                                        <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Button Grid.Column="1"
                                    Command="{Binding Settings.RefreshOutputDevicesCommand}"
                                    ToolTip.Tip="{Binding Localization.MixerRefresh}">
                                <Path Data="{StaticResource IconRefreshCw}" Classes="icon small" />
                            </Button>
                        </Grid>
                        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="{Binding Localization.HeaderBackend}" Classes="dim" FontSize="10" />
                                <TextBlock Text="{Binding Settings.AudioBackendLabel}" Classes="mono" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Text="{Binding Localization.SettingsSampleRate}" Classes="dim" FontSize="10" />
                                <TextBlock Text="{Binding Settings.AudioSampleRateLabel}" Classes="mono" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="2">
                                <TextBlock Text="{Binding Localization.SettingsBufferSize}" Classes="dim" FontSize="10" />
                                <TextBlock Text="{Binding Settings.AudioBufferSizeLabel}" Classes="mono" />
                            </StackPanel>
                            <StackPanel Grid.Column="3" Spacing="2">
                                <TextBlock Text="{Binding Localization.SettingsAudioMode}" Classes="dim" FontSize="10" />
                                <TextBlock Text="{Binding Settings.AudioModeLabel}" Classes="mono" />
                            </StackPanel>
                        </Grid>
                        <Button Content="{Binding Localization.SettingsTestAudio}"
                                Command="{Binding Settings.TestAudioOutputCommand}"
                                HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="0">
                    <Border Grid.Column="0" Classes="settingsPanel">
                        <StackPanel Spacing="10">
                            <TextBlock Text="{Binding Localization.SettingsMidiController}" FontWeight="Bold" />
                            <TextBlock Text="{Binding Settings.MidiEnabledLabel}" Classes="dim" />
                            <TextBlock Text="{Binding Settings.MidiPortLabel}" Classes="dim" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Command="{Binding Settings.ToggleMidiCommand}" Content="{Binding Localization.SettingsToggleMidi}" />
                                <Button Content="{Binding Localization.SettingsPrevPort}" Command="{Binding Settings.PreviousPortCommand}" />
                                <Button Content="{Binding Localization.SettingsNextPort}" Command="{Binding Settings.NextPortCommand}" />
                            </StackPanel>

                            <Border BorderBrush="{DynamicResource RythmboxPanelBorderBrush}" BorderThickness="0,1,0,0" Padding="0,10,0,0" Margin="0,4,0,0">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="{Binding Localization.SettingsFootSwitch}" FontWeight="Bold" />
                                    <TextBlock Text="{Binding Localization.SettingsFootSwitchHelp}" Classes="dim" TextWrapping="Wrap" />
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <TextBlock Text="{Binding Settings.FootSwitchCcLabel}" Classes="mono" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Settings.FootSwitchSignatureLabel}" Classes="mono" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Content="{Binding Localization.SettingsFootSwitchCcPrev}" Command="{Binding Settings.FootSwitchCcPrevCommand}" />
                                        <Button Content="{Binding Localization.SettingsFootSwitchCcNext}" Command="{Binding Settings.FootSwitchCcNextCommand}" />
                                        <Button Content="{Binding Localization.SettingsFootSwitchCycleSig}" Command="{Binding Settings.CycleFootSwitchSignatureCommand}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Classes="settingsPanel">
                        <StackPanel Spacing="10">
                            <TextBlock Text="{Binding Localization.SettingsKeyboardMapping}" FontWeight="Bold" />
                            <TextBlock Text="{Binding Localization.SettingsPlayStop}" Classes="dim" />
                            <TextBlock Text="{Binding Settings.KeyboardModeLabel}" Classes="dim" />
                            <Button Content="{Binding Localization.SettingsSwitchMode}" Command="{Binding Settings.ToggleKeyboardModeCommand}" HorizontalAlignment="Left" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Classes="settingsPanel">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{Binding Localization.SettingsMappingOptions}" FontWeight="Bold" />
                        <TextBlock Text="{Binding Localization.SettingsMappingHelp}"
                                   Classes="dim" TextWrapping="Wrap" />

                        <ItemsControl ItemsSource="{Binding Settings.Mappings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:PadMappingEntryViewModel">
                                    <Border Classes="mappingRow" Classes.learning="{Binding IsLearning}">
                                        <Grid ColumnDefinitions="100,80,80,*,Auto,Auto,Auto,Auto" Margin="0,4">
                                            <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding KeyboardKeyLabel}" Classes="dim" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" Text="{Binding MidiNoteLabel}" Classes="dim" VerticalAlignment="Center" />
                                            <Panel Grid.Column="3" />
                                            <Button Grid.Column="4" Command="{Binding ToggleLearnCommand}" Content="{Binding LearnLabel}" Margin="2,0" />
                                            <Button Grid.Column="5" Command="{Binding DecrementNoteCommand}" Content="-" Width="28" Margin="2,0" />
                                            <Button Grid.Column="6" Command="{Binding IncrementNoteCommand}" Content="+" Width="28" Margin="2,0" />
                                            <Button Grid.Column="7" Command="{Binding CycleKeyCommand}" Content="{Binding KeyNextLabel}" Margin="2,0" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
