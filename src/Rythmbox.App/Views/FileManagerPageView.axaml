<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Rythmbox.App.ViewModels"
             xmlns:views="using:Rythmbox.App.Views"
             mc:Ignorable="d" d:DesignWidth="1150" d:DesignHeight="720"
             x:Class="Rythmbox.App.Views.FileManagerPageView"
             x:DataType="vm:MainWindowViewModel">
    <Border Classes="region" Margin="8">
        <DockPanel LastChildFill="True">
            <TextBlock DockPanel.Dock="Top" Text="{Binding Localization.FilesTitle}" Classes="panelHeader" Margin="0,0,0,8" />
            <views:FileManagerBrowserView DataContext="{Binding FileManager}" />
        </DockPanel>
    </Border>
</UserControl>
