<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Rythmbox.App.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1150" d:DesignHeight="36"
             x:Class="Rythmbox.App.Views.NavBarView"
             x:DataType="vm:MainWindowViewModel">
    <Border Classes="navBar">
        <Grid ColumnDefinitions="Auto,*">
            <TextBlock Text="MODE" Classes="dim" FontSize="9" FontWeight="Bold"
                       LetterSpacing="1" VerticalAlignment="Center" Margin="4,0,12,0" />
            <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                          HorizontalAlignment="Stretch">
                <StackPanel Orientation="Horizontal" Spacing="4">
                <Button Classes="navTab" Classes.active="{Binding IsHomePage}"
                        Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:AppPage.Home}"
                        ToolTip.Tip="{Binding Localization.NavHome}">
                    <TextBlock Text="{Binding Localization.NavHome}" FontSize="11" TextTrimming="CharacterEllipsis" />
                </Button>
                <Button Classes="navTab" Classes.active="{Binding IsMachinePage}"
                        Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:AppPage.Machine}"
                        ToolTip.Tip="{Binding Localization.NavMachine}">
                    <TextBlock Text="{Binding Localization.NavMachine}" FontSize="11" TextTrimming="CharacterEllipsis" />
                </Button>
                <Button Classes="navTab" Classes.active="{Binding IsPadsPage}"
                        Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:AppPage.Pads}"
                        ToolTip.Tip="{Binding Localization.NavPads}">
                    <TextBlock Text="{Binding Localization.NavPads}" FontSize="11" TextTrimming="CharacterEllipsis" />
                </Button>
                <Button Classes="navTab" Classes.active="{Binding IsMixerPage}"
                        Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:AppPage.Mixer}"
                        ToolTip.Tip="{Binding Localization.NavMixer}">
                    <TextBlock Text="{Binding Localization.NavMixer}" FontSize="11" TextTrimming="CharacterEllipsis" />
                </Button>
                <Button Classes="navTab" Classes.active="{Binding IsEditorPage}"
                        Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:AppPage.Editor}"
                        ToolTip.Tip="{Binding Localization.NavEditor}">
                    <TextBlock Text="{Binding Localization.NavEditor}" FontSize="11" TextTrimming="CharacterEllipsis" />
                </Button>
                <Button Classes="navTab" Classes.active="{Binding IsMacroPage}"
                        Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:AppPage.Macro}"
                        ToolTip.Tip="{Binding Localization.NavMacro}">
                    <TextBlock Text="{Binding Localization.NavMacro}" FontSize="11" TextTrimming="CharacterEllipsis" />
                </Button>
                <Button Classes="navTab" Classes.active="{Binding IsFilesPage}"
                        Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:AppPage.Files}"
                        ToolTip.Tip="{Binding Localization.NavFiles}">
                    <TextBlock Text="{Binding Localization.NavFiles}" FontSize="11" TextTrimming="CharacterEllipsis" />
                </Button>
                <Button Classes="navTab" Classes.active="{Binding IsSettingsPage}"
                        Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:AppPage.Settings}"
                        ToolTip.Tip="{Binding Localization.NavSettings}">
                    <TextBlock Text="{Binding Localization.NavSettings}" FontSize="11" TextTrimming="CharacterEllipsis" />
                </Button>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
