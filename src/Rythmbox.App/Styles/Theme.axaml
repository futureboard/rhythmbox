    <Style Selector="Button.pianoRollNote.bar">
        <Setter Property="BorderBrush" Value="#4A4B56" />
    </Style>

    <Style Selector="Button.pianoRollNote.beat">
        <Setter Property="BorderBrush" Value="#35363F" />
    </Style>

    <Style Selector="Button.pianoRollNote:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#2A2B33" />
