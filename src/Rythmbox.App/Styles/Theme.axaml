<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Styles.Resources>
        <ResourceDictionary>
            <FontFamily x:Key="RythmboxUIFont">avares://Rythmbox.App/Assets/Fonts#Barlow, avares://Rythmbox.App/Assets/Fonts#Anuphan</FontFamily>
            <FontFamily x:Key="RythmboxUIInter">avares://Rythmbox.App/Assets/Fonts#Inter</FontFamily>
            <SolidColorBrush x:Key="RythmboxBackgroundBrush" Color="#1B1C22" />
            <SolidColorBrush x:Key="RythmboxPanelBrush" Color="#1B1C22" />
            <SolidColorBrush x:Key="RythmboxPanelBorderBrush" Color="#2E2F38" />
            <SolidColorBrush x:Key="RythmboxAccentBrush" Color="#FF8C1A" />
            <SolidColorBrush x:Key="RythmboxAccentHoverBrush" Color="#FFA542" />
            <SolidColorBrush x:Key="RythmboxTextBrush" Color="#EDEDEF" />
            <SolidColorBrush x:Key="RythmboxDimTextBrush" Color="#82838D" />
            <SolidColorBrush x:Key="RythmboxRedBrush" Color="#E5453B" />
            <SolidColorBrush x:Key="RythmboxRedHoverBrush" Color="#F0685F" />
            <SolidColorBrush x:Key="RythmboxGreenBrush" Color="#35D07F" />
            <SolidColorBrush x:Key="RythmboxPadBrush" Color="#26272E" />
        </ResourceDictionary>
    </Styles.Resources>

    <Style Selector="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource RythmboxUIFont}" />
    </Style>

    <Style Selector="Button">
        <Setter Property="FontFamily" Value="{StaticResource RythmboxUIFont}" />
    </Style>

    <Style Selector="ToggleButton">
        <Setter Property="FontFamily" Value="{StaticResource RythmboxUIFont}" />
    </Style>

    <Style Selector="ComboBox">
        <Setter Property="FontFamily" Value="{StaticResource RythmboxUIFont}" />
    </Style>

    <Style Selector="TextBox">
        <Setter Property="FontFamily" Value="{StaticResource RythmboxUIFont}" />
    </Style>

    <!-- Global: square corners everywhere -->
    <Style Selector="Button">
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style Selector="ToggleButton">
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style Selector="TextBox">
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style Selector="ComboBox">
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <!-- Master layout regions: flat panels divided by 1px lines, no rounding -->
    <Style Selector="Border.region">
        <Setter Property="Background" Value="{DynamicResource RythmboxPanelBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="8" />
    </Style>

    <Style Selector="Border.regionTop">
        <Setter Property="BorderThickness" Value="0,0,1,1" />
    </Style>

    <Style Selector="Border.regionRight">
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style Selector="Border.regionBottom">
        <Setter Property="BorderThickness" Value="0,0,1,0" />
    </Style>

    <Style Selector="Border.regionFill">
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="Border.panel">
        <Setter Property="Background" Value="{DynamicResource RythmboxPanelBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="8" />
    </Style>

    <Style Selector="Border.masterStrip">
        <Setter Property="Background" Value="{DynamicResource RythmboxPanelBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="8,6" />
    </Style>

    <Style Selector="TextBlock.panelHeader">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxTextBrush}" />
        <Setter Property="LetterSpacing" Value="1" />
    </Style>

    <Style Selector="TextBlock.dim">
        <Setter Property="Foreground" Value="{DynamicResource RythmboxDimTextBrush}" />
        <Setter Property="FontSize" Value="11" />
    </Style>

    <Style Selector="TextBlock.mono">
        <Setter Property="Foreground" Value="{DynamicResource RythmboxTextBrush}" />
    </Style>

    <Style Selector="Button.accent">
        <Setter Property="Background" Value="{DynamicResource RythmboxAccentBrush}" />
        <Setter Property="Foreground" Value="#1A1A1A" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxAccentHoverBrush}" />
    </Style>

    <Style Selector="Button.danger">
        <Setter Property="Background" Value="#3A2325" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxRedBrush}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#4A2B2D" />
    </Style>

    <Style Selector="ProgressBar">
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style Selector="ProgressBar.vuMeter">
        <Setter Property="Foreground" Value="#3DDC84" />
        <Setter Property="Background" Value="#2A2B31" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style Selector="ProgressBar.vuMeterPeak">
        <Setter Property="Foreground" Value="{DynamicResource RythmboxAccentBrush}" />
        <Setter Property="Background" Value="#2A2B31" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style Selector="Border.headerBar">
        <Setter Property="Background" Value="{DynamicResource RythmboxPanelBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="8,6" />
    </Style>

    <Style Selector="Border.badge">
        <Setter Property="Background" Value="#25201A" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxAccentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="6,2" />
    </Style>

    <Style Selector="Border.badge TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource RythmboxAccentBrush}" />
    </Style>

    <Style Selector="Border.footerBar">
        <Setter Property="Background" Value="{DynamicResource RythmboxPanelBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="8,4" />
    </Style>

    <Style Selector="Border.nowPlaying">
        <Setter Property="Background" Value="#152218" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="8" />
    </Style>

    <Style Selector="TextBlock.nowPlayingDim">
        <Setter Property="Foreground" Value="{DynamicResource RythmboxGreenBrush}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <Style Selector="ProgressBar.nowPlayingProgress">
        <Setter Property="Height" Value="4" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxGreenBrush}" />
        <Setter Property="Background" Value="#1F2C24" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style Selector="Button.transportStop">
        <Setter Property="Background" Value="{DynamicResource RythmboxRedBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style Selector="Button.transportStop:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxRedHoverBrush}" />
    </Style>

    <Style Selector="Button.pad">
        <Setter Property="Background" Value="{DynamicResource RythmboxPadBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Margin" Value="0" />
    </Style>

    <Style Selector="Button.pad:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#32333C" />
    </Style>

    <Style Selector="Button.pad.used">
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxRedBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="Background" Value="#3A2325" />
    </Style>

    <Style Selector="Button.patternPad">
        <Setter Property="Background" Value="{DynamicResource RythmboxPadBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Margin" Value="0" />
    </Style>

    <Style Selector="Button.patternPad:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#32333C" />
    </Style>

    <Style Selector="Button.patternPad.selected /template/ ContentPresenter">
        <Setter Property="Background" Value="#2A3548" />
        <Setter Property="BorderBrush" Value="#4A7FD4" />
    </Style>

    <Style Selector="Button.patternPad.playing /template/ ContentPresenter">
        <Setter Property="Background" Value="#1F3A28" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxGreenBrush}" />
    </Style>

    <Style Selector="Button.patternPad.queued /template/ ContentPresenter">
        <Setter Property="Background" Value="#3A3020" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxAccentBrush}" />
    </Style>

    <Style Selector="Button.patternPad.missing /template/ ContentPresenter">
        <Setter Property="Background" Value="#222328" />
        <Setter Property="Opacity" Value="0.45" />
    </Style>

    <Style Selector="Button.patternPad.stop /template/ ContentPresenter">
        <Setter Property="Background" Value="#3A2325" />
    </Style>

    <Style Selector="Button.patternPad.stop">
        <Setter Property="Foreground" Value="{DynamicResource RythmboxRedBrush}" />
    </Style>

    <Style Selector="Button.patternPad.tap /template/ ContentPresenter">
        <Setter Property="Background" Value="#25262E" />
    </Style>

    <Style Selector="Button.tapActive /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxAccentBrush}" />
    </Style>

    <Style Selector="TextBlock.patternPadLabel">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxTextBrush}" />
        <Setter Property="TextAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.padNumber">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxDimTextBrush}" />
    </Style>

    <Style Selector="TextBlock.padLabel">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxTextBrush}" />
        <Setter Property="LetterSpacing" Value="0.5" />
    </Style>

    <!-- Mixer surface (ported from Futureboard SphereUIComponents) -->
    <Style Selector="Border.mixerPageHeader">
        <Setter Property="Background" Value="{DynamicResource RythmboxPanelBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style Selector="Border.mixerCountBadge">
        <Setter Property="Background" Value="#25262E" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Padding" Value="5,1" />
    </Style>

    <Style Selector="Border.mixerFxPanel">
        <Setter Property="Background" Value="#1A1B22" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
    </Style>

    <Style Selector="Border.mixerSurfaceCanvas">
        <Setter Property="Background" Value="#181920" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,0" />
    </Style>

    <Style Selector="Border.mixerStrip">
        <Setter Property="Background" Value="#1F2027" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="MinHeight" Value="320" />
    </Style>

    <Style Selector="Border.mixerStrip:pointerover">
        <Setter Property="Background" Value="#23242C" />
    </Style>

    <Style Selector="Border.mixerStrip.selected">
        <Setter Property="Background" Value="#252A35" />
        <Setter Property="BorderBrush" Value="#4A7FD4" />
    </Style>

    <Style Selector="Border.mixerStrip.master">
        <Setter Property="Background" Value="#22232B" />
        <Setter Property="BorderThickness" Value="1,0,0,0" />
    </Style>

    <Style Selector="Border.mixerStrip.group">
        <Setter Property="Background" Value="#21222A" />
    </Style>

    <Style Selector="Border.mixerStripHeader">
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style Selector="Border.mixerStripFooter">
        <Setter Property="Background" Value="#1A1B22" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1,0,0,0" />
    </Style>

    <Style Selector="Border.mixerStripAccent">
        <Setter Property="Background" Value="#4A7FD4" />
    </Style>

    <Style Selector="Border.mixerStripAccent.drum">
        <Setter Property="Background" Value="#4A7FD4" />
    </Style>

    <Style Selector="Border.mixerStripAccent.perc">
        <Setter Property="Background" Value="#D97B2E" />
    </Style>

    <Style Selector="Border.mixerStripAccent.cym">
        <Setter Property="Background" Value="#7B6BB8" />
    </Style>

    <Style Selector="Border.mixerStripAccent.master">
        <Setter Property="Background" Value="#5A8FD4" />
    </Style>

    <Style Selector="Border.mixerStripAccentBar">
        <Setter Property="Background" Value="#4A7FD4" />
    </Style>

    <Style Selector="Border.mixerStripAccentBar.drum">
        <Setter Property="Background" Value="#4A7FD4" />
    </Style>

    <Style Selector="Border.mixerStripAccentBar.perc">
        <Setter Property="Background" Value="#D97B2E" />
    </Style>

    <Style Selector="Border.mixerStripAccentBar.cym">
        <Setter Property="Background" Value="#7B6BB8" />
    </Style>

    <Style Selector="Border.mixerStripAccentBar.master">
        <Setter Property="Background" Value="#5A8FD4" />
    </Style>

    <Style Selector="TextBlock.mixerStripName">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxTextBrush}" />
    </Style>

    <Style Selector="TextBlock.mixerStripMeta">
        <Setter Property="FontSize" Value="7.5" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxDimTextBrush}" />
    </Style>

    <Style Selector="TextBlock.mixerStripRoute">
        <Setter Property="FontSize" Value="9" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxDimTextBrush}" />
    </Style>

    <Style Selector="TextBlock.mixerScaleMark">
        <Setter Property="FontSize" Value="7" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxDimTextBrush}" />
    </Style>

    <Style Selector="TextBlock.mixerMeterHint">
        <Setter Property="FontSize" Value="7" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxDimTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="MaxWidth" Value="48" />
        <Setter Property="TextAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.mixerDbPill">
        <Setter Property="Background" Value="#25262E" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="MinWidth" Value="52" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.mixerDbPill.selected">
        <Setter Property="BorderBrush" Value="#4A7FD4" />
    </Style>

    <Style Selector="TextBlock.mixerDbPillValue">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxTextBrush}" />
    </Style>

    <Style Selector="TextBlock.mixerDbPillUnit">
        <Setter Property="FontSize" Value="8" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxDimTextBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.mixerDbPillText">
        <Setter Property="FontSize" Value="8" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxGreenBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.mixerMeterTrack">
        <Setter Property="Background" Value="#14151A" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="1" />
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="MinHeight" Value="108" />
        <Setter Property="MinWidth" Value="8" />
    </Style>

    <Style Selector="Border.mixerMeterFill">
        <Setter Property="Background" Value="#3D8B5A" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="MinHeight" Value="2" />
    </Style>

    <Style Selector="Border.mixerMeterFill.clip">
        <Setter Property="Background" Value="{DynamicResource RythmboxRedBrush}" />
    </Style>

    <Style Selector="Slider.mixerFaderV">
        <Setter Property="Width" Value="24" />
        <Setter Property="MinHeight" Value="120" />
    </Style>

    <Style Selector="ToggleButton.mixerMsBtn">
        <Setter Property="FontSize" Value="9" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="MinWidth" Value="28" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Background" Value="#25262E" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxDimTextBrush}" />
    </Style>

    <Style Selector="ToggleButton.mixerFxSlot">
        <Setter Property="FontSize" Value="7.5" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Padding" Value="0,3" />
        <Setter Property="MinHeight" Value="18" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Background" Value="#1E1F26" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxDimTextBrush}" />
    </Style>

    <Style Selector="ToggleButton.mixerFxSlot:checked /template/ ContentPresenter">
        <Setter Property="Background" Value="#4A7FD4" />
    </Style>

    <Style Selector="ToggleButton.mixerFxSlot:checked">
        <Setter Property="Foreground" Value="White" />
    </Style>

    <Style Selector="Border.mixerFxSlots">
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style Selector="ToggleButton.mixerMsBtn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#32333C" />
    </Style>

    <Style Selector="ToggleButton.mixerMsBtn.mute:checked /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxRedBrush}" />
    </Style>

    <Style Selector="ToggleButton.mixerMsBtn.mute:checked">
        <Setter Property="Foreground" Value="White" />
    </Style>

    <Style Selector="ToggleButton.mixerMsBtn.solo:checked /template/ ContentPresenter">
        <Setter Property="Background" Value="#E5B93B" />
    </Style>

    <Style Selector="ToggleButton.mixerMsBtn.solo:checked">
        <Setter Property="Foreground" Value="#1A1A1A" />
    </Style>

    <!-- Legacy mixer styles kept for old views if referenced -->
    <Style Selector="Border.mixerChannel">
        <Setter Property="Background" Value="#1F2027" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="2,6" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="MinHeight" Value="160" />
    </Style>

    <Style Selector="TextBlock.mixerChannelLabel">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxTextBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style Selector="TextBlock.mixerChannelDb">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxGreenBrush}" />
    </Style>

    <Style Selector="Slider.mixerFader">
        <Setter Property="Width" Value="28" />
        <Setter Property="Height" Value="100" />
    </Style>

    <Style Selector="ToggleButton.mixerMute, ToggleButton.mixerSolo">
        <Setter Property="FontSize" Value="9" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Padding" Value="0,3" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style Selector="ToggleButton.mixerMute:checked /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxRedBrush}" />
    </Style>

    <Style Selector="ToggleButton.mixerMute:checked">
        <Setter Property="Foreground" Value="White" />
    </Style>

    <Style Selector="ToggleButton.mixerSolo:checked /template/ ContentPresenter">
        <Setter Property="Background" Value="#E5B93B" />
    </Style>

    <Style Selector="ToggleButton.mixerSolo:checked">
        <Setter Property="Foreground" Value="#1A1A1A" />
    </Style>

    <Style Selector="Border.categoryTag">
        <Setter Property="Background" Value="#2D5FE0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="0,2" />
    </Style>

    <Style Selector="Border.categoryTag TextBlock">
        <Setter Property="FontSize" Value="8" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <Style Selector="Border.categoryTag.perc">
        <Setter Property="Background" Value="#D97B2E" />
    </Style>

    <Style Selector="Border.categoryTag.cym">
        <Setter Property="Background" Value="#8B5CF6" />
    </Style>

    <Style Selector="Border.navBar">
        <Setter Property="Background" Value="{DynamicResource RythmboxPanelBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="Button.navTab">
        <Setter Property="MinWidth" Value="72" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="BorderThickness" Value="0,0,1,0" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.toolbarBtn">
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.homeTile">
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="MinHeight" Value="76" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="#1F2027" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>

    <Style Selector="Button.homeTile:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#282A34" />
    </Style>

    <Style Selector="Button.navTab.active /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxAccentBrush}" />
    </Style>

    <Style Selector="Button.navTab.active">
        <Setter Property="Foreground" Value="#1A1A1A" />
    </Style>

    <Style Selector="Rectangle.beatLed">
        <Setter Property="Width" Value="8" />
        <Setter Property="Height" Value="8" />
        <Setter Property="Fill" Value="{DynamicResource RythmboxAccentBrush}" />
    </Style>

    <Style Selector="Border.settingsPanel">
        <Setter Property="Background" Value="#1C1D24" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="Padding" Value="8" />
    </Style>

    <Style Selector="Border.mappingRow">
        <Setter Property="Background" Value="#22232A" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style Selector="Border.mappingRow.learning">
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxAccentBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,2" />
    </Style>

    <Style Selector="Border.bankList">
        <Setter Property="Background" Value="#16171C" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,0" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="Border.popupOverlay">
        <Setter Property="Background" Value="#AA000000" />
    </Style>

    <Style Selector="Border.popupPanel">
        <Setter Property="Background" Value="{DynamicResource RythmboxPanelBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="12" />
    </Style>

    <Style Selector="TextBlock.placeholderTitle">
        <Setter Property="FontSize" Value="36" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxDimTextBrush}" />
    </Style>

    <Style Selector="ListBox.loopList">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="ListBox.loopList ListBoxItem">
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style Selector="ListBox.loopList ListBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxRedBrush}" />
    </Style>

    <Style Selector="ListBox.loopList ListBoxItem:selected TextBlock">
        <Setter Property="Foreground" Value="White" />
    </Style>

    <Style Selector="Path.icon">
        <Setter Property="Stretch" Value="Uniform" />
        <Setter Property="Fill" Value="Transparent" />
        <Setter Property="Stroke" Value="{DynamicResource RythmboxTextBrush}" />
        <Setter Property="StrokeThickness" Value="2" />
        <Setter Property="StrokeLineCap" Value="Round" />
        <Setter Property="StrokeJoin" Value="Round" />
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
    </Style>

    <Style Selector="Path.icon.dim">
        <Setter Property="Stroke" Value="{DynamicResource RythmboxDimTextBrush}" />
    </Style>

    <Style Selector="Path.icon.accent">
        <Setter Property="Stroke" Value="{DynamicResource RythmboxAccentBrush}" />
    </Style>

    <Style Selector="Path.icon.danger">
        <Setter Property="Stroke" Value="{DynamicResource RythmboxRedBrush}" />
    </Style>

    <Style Selector="Path.icon.small">
        <Setter Property="Width" Value="13" />
        <Setter Property="Height" Value="13" />
    </Style>

    <Style Selector="Border.stepHeader">
        <Setter Property="Background" Value="#1A1B20" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style Selector="Border.stepPadLabel">
