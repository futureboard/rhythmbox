    <Style Selector="Button.stepCell.barStart">
        <Setter Property="BorderBrush" Value="#4A4B56" />
    </Style>

    <Style Selector="Button.stepCell.active /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxAccentBrush}" />
    </Style>

    <Style Selector="Button.stepCell.playing /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxGreenBrush}" />
