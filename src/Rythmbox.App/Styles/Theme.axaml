<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StyleInclude Source="avares://Rythmbox.UI/Styles/RythmboxTheme.axaml" />

    <!-- Domain-specific layout and hardware-rack styles (pads, mixer, editor, etc.) -->
    <Style Selector="Border.region">
        <Setter Property="Background" Value="{DynamicResource RythmboxPanelBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="8" />
    </Style>

    <Style Selector="Border.regionTop">
        <Setter Property="BorderThickness" Value="0,0,1,1" />
    </Style>

    <Style Selector="Border.regionRight">
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style Selector="Border.regionBottom">
        <Setter Property="BorderThickness" Value="0,0,1,0" />
    </Style>

    <Style Selector="Border.regionFill">
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="Border.panel">
        <Setter Property="Background" Value="{DynamicResource RythmboxPanelBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="8" />
    </Style>

    <Style Selector="Border.masterStrip">
        <Setter Property="Background" Value="{DynamicResource RythmboxPanelBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="8,6" />
    </Style>

    <Style Selector="TextBlock.panelHeader">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxTextBrush}" />
        <Setter Property="LetterSpacing" Value="1" />
    </Style>

    <Style Selector="TextBlock.dim">
        <Setter Property="Foreground" Value="{DynamicResource RythmboxDimTextBrush}" />
        <Setter Property="FontSize" Value="11" />
    </Style>

    <Style Selector="TextBlock.mono">
        <Setter Property="Foreground" Value="{DynamicResource RythmboxTextBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource RythmboxUIMono}" />
    </Style>

    <!-- Legacy accent/danger kept for domain views; base styles live in Rythmbox.UI -->

    <Style Selector="ProgressBar">
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style Selector="ProgressBar.vuMeter">
        <Setter Property="Foreground" Value="{DynamicResource RythmboxMeterFillBrush}" />
        <Setter Property="Background" Value="{DynamicResource RythmboxMeterTrackBrush}" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style Selector="ProgressBar.vuMeterPeak">
        <Setter Property="Foreground" Value="{DynamicResource RythmboxAccentBrush}" />
        <Setter Property="Background" Value="{DynamicResource RythmboxMeterTrackBrush}" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style Selector="Border.headerBar">
        <Setter Property="Background" Value="{DynamicResource RythmboxPanelBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="8,5" />
    </Style>

    <Style Selector="Border.audioStatusChip">
        <Setter Property="Background" Value="{DynamicResource RythmboxElevatedBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Padding" Value="8,3" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.audioStatusChip TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource RythmboxSecondaryTextBrush}" />
    </Style>

    <Style Selector="Border.badge">
        <Setter Property="Background" Value="#25201A" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxAccentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="6,2" />
    </Style>

    <Style Selector="Border.badge TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource RythmboxAccentBrush}" />
    </Style>

    <Style Selector="Border.footerBar">
        <Setter Property="Background" Value="{DynamicResource RythmboxPanelBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="8,4" />
    </Style>

    <Style Selector="Border.nowPlaying">
        <Setter Property="Background" Value="#152218" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="8" />
    </Style>

    <Style Selector="TextBlock.nowPlayingDim">
        <Setter Property="Foreground" Value="{DynamicResource RythmboxGreenBrush}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <Style Selector="ProgressBar.nowPlayingProgress">
        <Setter Property="Height" Value="4" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxGreenBrush}" />
        <Setter Property="Background" Value="#1F2C24" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style Selector="Button.transportStop">
        <Setter Property="Background" Value="{DynamicResource RythmboxRedBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style Selector="Button.transportStop:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxRedHoverBrush}" />
    </Style>

    <Style Selector="Button.pad">
        <Setter Property="Background" Value="{DynamicResource RythmboxPadBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="RenderTransformOrigin" Value="50%,50%" />
    </Style>

    <Style Selector="Button.pad:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxHoverBrush}" />
    </Style>

    <Style Selector="Button.pad.used">
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxRedBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="Background" Value="{DynamicResource RythmboxDangerSurfaceBrush}" />
    </Style>

    <Style Selector="Button.pad.empty">
        <Setter Property="Opacity" Value="0.55" />
    </Style>

    <Style Selector="Button.pad.pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxDangerHoverBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxAccentBrush}" />
    </Style>

    <Style Selector="Button.pad.pressed">
        <Setter Property="RenderTransform" Value="scale(0.96)" />
    </Style>

    <Style Selector="Ellipse.padSampleDot">
        <Setter Property="Fill" Value="{DynamicResource RythmboxBorderBrush}" />
    </Style>

    <Style Selector="Ellipse.padSampleDot.hasSample">
        <Setter Property="Fill" Value="{DynamicResource RythmboxGreenBrush}" />
    </Style>

    <Style Selector="Button.patternPad">
        <Setter Property="Background" Value="{DynamicResource RythmboxPadBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Margin" Value="0" />
    </Style>

    <Style Selector="Button.patternPad:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxHoverBrush}" />
    </Style>

    <Style Selector="Button.patternPad.selected /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxSelectedBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RbControlActiveBorderBrush}" />
    </Style>

    <Style Selector="Button.patternPad.playing /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxPlayingBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxGreenBrush}" />
    </Style>

    <Style Selector="Button.patternPad.queued /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxQueuedBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxAccentBrush}" />
    </Style>

    <Style Selector="Button.patternPad.missing /template/ ContentPresenter">
        <Setter Property="Background" Value="#222328" />
        <Setter Property="Opacity" Value="0.45" />
    </Style>

    <Style Selector="Button.patternPad.stop /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxDangerSurfaceBrush}" />
    </Style>

    <Style Selector="Button.patternPad.stop">
        <Setter Property="Foreground" Value="{DynamicResource RythmboxRedBrush}" />
    </Style>

    <Style Selector="Button.patternPad.tap /template/ ContentPresenter">
        <Setter Property="Background" Value="#25262E" />
    </Style>

    <Style Selector="Button.tapActive /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxAccentBrush}" />
    </Style>

    <Style Selector="TextBlock.patternPadLabel">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxTextBrush}" />
        <Setter Property="TextAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.padNumber">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxDimTextBrush}" />
    </Style>

    <Style Selector="TextBlock.padLabel">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxTextBrush}" />
        <Setter Property="LetterSpacing" Value="0.5" />
    </Style>

    <!-- User hotload rack (Pads page) -->
    <Style Selector="Button.hotloadSlot">
        <Setter Property="Background" Value="#25262E" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="2" />
    </Style>

    <Style Selector="Button.hotloadSlot:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#2E3038" />
    </Style>

    <Style Selector="Button.hotloadSlot.empty">
        <Setter Property="BorderBrush" Value="#3A3B44" />
        <Setter Property="Opacity" Value="0.85" />
    </Style>

    <Style Selector="Button.hotloadSlot.empty /template/ ContentPresenter">
        <Setter Property="Background" Value="#1E1F26" />
    </Style>

    <Style Selector="Button.hotloadSlot.active /template/ ContentPresenter">
        <Setter Property="Background" Value="#2A3548" />
        <Setter Property="BorderBrush" Value="#4A7FD4" />
    </Style>

    <Style Selector="Button.hotloadSlot.active">
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxAccentBrush}" />
    </Style>

    <Style Selector="TextBlock.hotloadSlotLabel">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxTextBrush}" />
    </Style>

    <Style Selector="TextBlock.hotloadSlotHint">
        <Setter Property="FontSize" Value="8" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxDimTextBrush}" />
        <Setter Property="FontStyle" Value="Italic" />
    </Style>

    <Style Selector="Button.hotloadSlot.empty TextBlock.hotloadSlotLabel">
        <Setter Property="Foreground" Value="{DynamicResource RythmboxDimTextBrush}" />
        <Setter Property="FontWeight" Value="Normal" />
    </Style>

    <!-- Mixer surface (ported from Futureboard SphereUIComponents) -->
    <Style Selector="Border.mixerPageHeader">
        <Setter Property="Background" Value="{DynamicResource RythmboxPanelBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style Selector="Border.mixerCountBadge">
        <Setter Property="Background" Value="#25262E" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Padding" Value="5,1" />
    </Style>

    <Style Selector="Border.mixerFxPanel">
        <Setter Property="Background" Value="#16171D" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
    </Style>

    <Style Selector="TextBlock.mixerFxSection">
        <Setter Property="FontSize" Value="9" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxDimTextBrush}" />
        <Setter Property="LetterSpacing" Value="0.8" />
        <Setter Property="Margin" Value="0,0,0,4" />
    </Style>

    <Style Selector="Border.mixerSurfaceCanvas">
        <Setter Property="Background" Value="#14151A" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="8,6,8,0" />
    </Style>

    <Style Selector="ScrollViewer.mixerSurfaceScroll">
        <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
        <Setter Property="VerticalScrollBarVisibility" Value="Disabled" />
    </Style>

    <Style Selector="Border.mixerStrip">
        <Setter Property="Background" Value="#1F2027" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="MinHeight" Value="340" />
        <Setter Property="Margin" Value="0,0,1,0" />
    </Style>

    <Style Selector="Border.mixerStrip:pointerover">
        <Setter Property="Background" Value="#262830" />
    </Style>

    <Style Selector="Border.mixerStrip.selected">
        <Setter Property="Background" Value="#282E3A" />
        <Setter Property="BorderBrush" Value="#5A8FD4" />
        <Setter Property="BorderThickness" Value="0,0,2,0" />
    </Style>

    <Style Selector="Border.mixerStrip.master">
        <Setter Property="Background" Value="#22232B" />
        <Setter Property="BorderThickness" Value="2,0,0,0" />
        <Setter Property="BorderBrush" Value="#4A7FD4" />
        <Setter Property="Margin" Value="4,0,0,0" />
    </Style>

    <Style Selector="Border.mixerStrip.group">
        <Setter Property="Background" Value="#21222A" />
    </Style>

    <Style Selector="Border.mixerStripHeader">
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style Selector="Border.mixerStripFooter">
        <Setter Property="Background" Value="#1A1B22" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1,0,0,0" />
    </Style>

    <Style Selector="Border.mixerStripAccent">
        <Setter Property="Background" Value="#4A7FD4" />
    </Style>

    <Style Selector="Border.mixerStripAccent.drum">
        <Setter Property="Background" Value="#4A7FD4" />
    </Style>

    <Style Selector="Border.mixerStripAccent.perc">
        <Setter Property="Background" Value="#D97B2E" />
    </Style>

    <Style Selector="Border.mixerStripAccent.cym">
        <Setter Property="Background" Value="#7B6BB8" />
    </Style>

    <Style Selector="Border.mixerStripAccent.master">
        <Setter Property="Background" Value="#5A8FD4" />
    </Style>

    <Style Selector="Border.mixerStripAccentBar">
        <Setter Property="Background" Value="#4A7FD4" />
    </Style>

    <Style Selector="Border.mixerStripAccentBar.drum">
        <Setter Property="Background" Value="#4A7FD4" />
    </Style>

    <Style Selector="Border.mixerStripAccentBar.perc">
        <Setter Property="Background" Value="#D97B2E" />
    </Style>

    <Style Selector="Border.mixerStripAccentBar.cym">
        <Setter Property="Background" Value="#7B6BB8" />
    </Style>

    <Style Selector="Border.mixerStripAccentBar.master">
        <Setter Property="Background" Value="#5A8FD4" />
    </Style>

    <Style Selector="TextBlock.mixerStripName">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxTextBrush}" />
    </Style>

    <Style Selector="TextBlock.mixerStripMeta">
        <Setter Property="FontSize" Value="7.5" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxDimTextBrush}" />
    </Style>

    <Style Selector="TextBlock.mixerStripRoute">
        <Setter Property="FontSize" Value="9" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxDimTextBrush}" />
    </Style>

    <Style Selector="TextBlock.mixerScaleMark">
        <Setter Property="FontSize" Value="7" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxDimTextBrush}" />
    </Style>

    <Style Selector="TextBlock.mixerMeterHint">
        <Setter Property="FontSize" Value="7" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxDimTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="MaxWidth" Value="48" />
        <Setter Property="TextAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.mixerDbPill">
        <Setter Property="Background" Value="#25262E" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="MinWidth" Value="52" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.mixerDbPill.selected">
        <Setter Property="BorderBrush" Value="#4A7FD4" />
    </Style>

    <Style Selector="TextBlock.mixerDbPillValue">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxTextBrush}" />
    </Style>

    <Style Selector="TextBlock.mixerDbPillUnit">
        <Setter Property="FontSize" Value="8" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxDimTextBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.mixerDbPillText">
        <Setter Property="FontSize" Value="8" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxGreenBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.mixerMeterTrack">
        <Setter Property="Background" Value="#14151A" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="1" />
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="MinHeight" Value="108" />
        <Setter Property="MinWidth" Value="8" />
    </Style>

    <Style Selector="Border.mixerMeterFill">
        <Setter Property="Background" Value="#3D8B5A" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="MinHeight" Value="2" />
    </Style>

    <Style Selector="Border.mixerMeterFill.clip">
        <Setter Property="Background" Value="{DynamicResource RythmboxRedBrush}" />
    </Style>

    <Style Selector="Slider.mixerFaderV">
        <Setter Property="Width" Value="24" />
        <Setter Property="MinHeight" Value="120" />
    </Style>

    <Style Selector="ToggleButton.mixerMsBtn">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinHeight" Value="26" />
        <Setter Property="MinWidth" Value="28" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Background" Value="{DynamicResource RbControlPressedBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxDimTextBrush}" />
    </Style>

    <!-- Insert slots: low-contrast when off, accent when on — not debug toggles -->
    <Style Selector="ToggleButton.mixerFxSlot">
        <Setter Property="FontSize" Value="8" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="0,3" />
        <Setter Property="MinHeight" Value="18" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxPlaceholderBrush}" />
        <Setter Property="Opacity" Value="0.55" />
    </Style>

    <Style Selector="ToggleButton.mixerFxSlot:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxHoverBrush}" />
    </Style>

    <Style Selector="ToggleButton.mixerFxSlot:checked">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxAccentBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxAccentBrush}" />
        <Setter Property="Background" Value="{DynamicResource RythmboxAccentMutedBrush}" />
    </Style>

    <Style Selector="ToggleButton.mixerFxSlot:checked /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxAccentMutedBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxAccentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxAccentBrush}" />
    </Style>

    <Style Selector="Border.mixerFxSlots">
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style Selector="ToggleButton.mixerMsBtn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxHoverBrush}" />
    </Style>

    <Style Selector="ToggleButton.mixerMsBtn.mute:checked /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxRedBrush}" />
    </Style>

    <Style Selector="ToggleButton.mixerMsBtn.mute:checked">
        <Setter Property="Foreground" Value="White" />
    </Style>

    <Style Selector="ToggleButton.mixerMsBtn.solo:checked /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxSoloBrush}" />
    </Style>

    <Style Selector="ToggleButton.mixerMsBtn.solo:checked">
        <Setter Property="Foreground" Value="{DynamicResource RythmboxOnAccentBrush}" />
    </Style>

    <!-- Legacy mixer styles kept for old views if referenced -->
    <Style Selector="Border.mixerChannel">
        <Setter Property="Background" Value="#1F2027" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="2,6" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="MinHeight" Value="160" />
    </Style>

    <Style Selector="TextBlock.mixerChannelLabel">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxTextBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style Selector="TextBlock.mixerChannelDb">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxGreenBrush}" />
    </Style>

    <Style Selector="Slider.mixerFader">
        <Setter Property="Width" Value="28" />
        <Setter Property="Height" Value="100" />
    </Style>

    <Style Selector="ToggleButton.mixerMute, ToggleButton.mixerSolo">
        <Setter Property="FontSize" Value="9" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Padding" Value="0,3" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style Selector="ToggleButton.mixerMute:checked /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxRedBrush}" />
    </Style>

    <Style Selector="ToggleButton.mixerMute:checked">
        <Setter Property="Foreground" Value="White" />
    </Style>

    <Style Selector="ToggleButton.mixerSolo:checked /template/ ContentPresenter">
        <Setter Property="Background" Value="#E5B93B" />
    </Style>

    <Style Selector="ToggleButton.mixerSolo:checked">
        <Setter Property="Foreground" Value="#1A1A1A" />
    </Style>

    <Style Selector="Border.categoryTag">
        <Setter Property="Background" Value="#2D5FE0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="0,2" />
    </Style>

    <Style Selector="Border.categoryTag TextBlock">
        <Setter Property="FontSize" Value="8" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <Style Selector="Border.categoryTag.perc">
        <Setter Property="Background" Value="{DynamicResource RythmboxPercAccentBrush}" />
    </Style>

    <Style Selector="Border.categoryTag.cym">
        <Setter Property="Background" Value="{DynamicResource RythmboxCymAccentBrush}" />
    </Style>

    <Style Selector="Border.navBar">
        <Setter Property="Background" Value="{DynamicResource RythmboxPanelBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="Button.navTab">
        <Setter Property="MinWidth" Value="48" />
        <Setter Property="MaxWidth" Value="140" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="BorderThickness" Value="0,0,1,0" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.navTabSecondary">
        <Setter Property="MinWidth" Value="40" />
        <Setter Property="MaxWidth" Value="160" />
        <Setter Property="Opacity" Value="0.9" />
    </Style>

    <Style Selector="Button.toolbarBtn">
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.homeTile">
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="MinHeight" Value="76" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="{DynamicResource RythmboxElevatedBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="2" />
    </Style>

    <Style Selector="Button.homeTile:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxHoverBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxBorderBrush}" />
    </Style>

    <!-- Mode nav: underline accent instead of full bright block -->
    <Style Selector="Button.navTab.active /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxAccentMutedBrush}" />
    </Style>

    <Style Selector="Button.navTab.active">
        <Setter Property="Foreground" Value="{DynamicResource RythmboxAccentBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxAccentBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,2" />
    </Style>

    <Style Selector="Button.navTab:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxHoverBrush}" />
    </Style>

    <Style Selector="Button.transportPlay">
        <Setter Property="Background" Value="{DynamicResource RythmboxAccentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxOnAccentBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxAccentPressedBrush}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="MinWidth" Value="36" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="Padding" Value="8,4" />
    </Style>

    <Style Selector="Button.transportPlay:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxAccentHoverBrush}" />
    </Style>

    <Style Selector="Button.transportPlay.playing">
        <Setter Property="Background" Value="{DynamicResource RythmboxDangerSurfaceBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxRedBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxDangerBorderBrush}" />
    </Style>

    <Style Selector="ToggleButton.transportLoop:checked /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxAccentMutedBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxAccentBrush}" />
    </Style>

    <Style Selector="ToggleButton.transportLoop:checked">
        <Setter Property="Foreground" Value="{DynamicResource RythmboxAccentBrush}" />
    </Style>

    <Style Selector="Rectangle.beatLed">
        <Setter Property="Width" Value="8" />
        <Setter Property="Height" Value="8" />
        <Setter Property="Fill" Value="{DynamicResource RythmboxAccentBrush}" />
    </Style>

    <Style Selector="Border.settingsPanel">
        <Setter Property="Background" Value="#1C1D24" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="Padding" Value="8" />
    </Style>

    <Style Selector="Border.mappingRow">
        <Setter Property="Background" Value="#22232A" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style Selector="Border.mappingRow.learning">
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxAccentBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,2" />
    </Style>

    <Style Selector="Border.bankList">
        <Setter Property="Background" Value="#16171C" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,0" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="Border.popupOverlay">
        <Setter Property="Background" Value="{DynamicResource RythmboxOverlayBrush}" />
    </Style>

    <Style Selector="Border.popupPanel">
        <Setter Property="Background" Value="{DynamicResource RythmboxPanelBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="12" />
    </Style>

    <Style Selector="TextBlock.placeholderTitle">
        <Setter Property="FontSize" Value="36" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource RythmboxDimTextBrush}" />
    </Style>

    <Style Selector="ListBox.loopList">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="ListBox.loopList ListBoxItem">
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style Selector="ListBox.loopList ListBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxRedBrush}" />
    </Style>

    <Style Selector="ListBox.loopList ListBoxItem:selected TextBlock">
        <Setter Property="Foreground" Value="White" />
    </Style>

    <!-- Path.icon (+ .small/.dim/.accent/.danger) is defined once in the shared
         Rythmbox.UI kit (Styles/Controls.axaml). Do not redefine it here. -->

    <Style Selector="Border.stepHeader">
        <Setter Property="Background" Value="#1A1B20" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style Selector="Border.stepPadLabel">
        <Setter Property="Background" Value="#2D5FE0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="MinHeight" Value="28" />
    </Style>

    <Style Selector="Border.stepPadLabel.perc">
        <Setter Property="Background" Value="#D97B2E" />
    </Style>

    <Style Selector="Button.stepCell">
        <Setter Property="Background" Value="#26272E" />
        <Setter Property="BorderBrush" Value="#35363F" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style Selector="Button.stepCell.barStart">
        <Setter Property="BorderBrush" Value="#4A4B56" />
    </Style>

    <Style Selector="Button.stepCell.active /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxAccentBrush}" />
    </Style>

    <Style Selector="Button.stepCell.playing /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxGreenBrush}" />
    </Style>

    <Style Selector="Border.pianoRollToolbar">
        <Setter Property="Background" Value="#1A1B20" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style Selector="Border.pianoRollCorner">
        <Setter Property="Background" Value="#16171C" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="MinHeight" Value="24" />
    </Style>

    <Style Selector="Border.pianoRollRuler">
        <Setter Property="Background" Value="#1A1B20" />
        <Setter Property="BorderBrush" Value="#2A2B33" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
    </Style>

    <Style Selector="Border.pianoRollRuler.bar">
        <Setter Property="BorderBrush" Value="#4A4B56" />
        <Setter Property="Background" Value="#1E1F26" />
    </Style>

    <Style Selector="Border.pianoRollRuler.beat">
        <Setter Property="BorderBrush" Value="#35363F" />
    </Style>

    <Style Selector="Grid.pianoRollLane">
        <Setter Property="Background" Value="#1B1C22" />
    </Style>

    <Style Selector="Grid.pianoRollLane.alt">
        <Setter Property="Background" Value="#17181E" />
    </Style>

    <Style Selector="Border.pianoRollLaneHeader">
        <Setter Property="Background" Value="#22232A" />
        <Setter Property="BorderBrush" Value="{DynamicResource RythmboxPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="MinHeight" Value="24" />
    </Style>

    <Style Selector="Border.pianoRollLaneHeader.perc">
        <Setter Property="Background" Value="#25221C" />
    </Style>

    <Style Selector="Button.pianoRollNote">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="#2A2B33" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Margin" Value="0" />
    </Style>

    <Style Selector="Button.pianoRollNote.bar">
        <Setter Property="BorderBrush" Value="#4A4B56" />
    </Style>

    <Style Selector="Button.pianoRollNote.beat">
        <Setter Property="BorderBrush" Value="#35363F" />
    </Style>

    <Style Selector="Button.pianoRollNote:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#2A2B33" />
    </Style>

    <Style Selector="Button.pianoRollNote.active /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxAccentBrush}" />
    </Style>

    <Style Selector="Button.pianoRollNote.playing /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource RythmboxGreenBrush}" />
    </Style>

    <Style Selector="Border.waveformPanel">
        <Setter Property="Background" Value="#121318" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="MinHeight" Value="100" />
    </Style>

</Styles>
